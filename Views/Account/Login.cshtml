@model TechSolutions.Models.LoginViewModel
@{
    ViewBag.Title = "Sign In";
    Layout = null;
}

@* I merged the defualt ASP MVC login and register pages into one and completely re-styled them to fit my theme and give TechSolutions a real company feel *@

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TechSolutions — Sign In</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500&display=swap');

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --navy: #07020D;
            --navy-mid: #0d0820;
            --primary: #0477bf;
            --primary-glow: #0477bf55;
            --teal: #04c4d9;
            --teal-dim: #04c4d933;
            --surface: #ffffff;
            --bg-light: #f0f5f9;
            --text: #1a2733;
            --muted: #6b7c8d;
            --border: #d6e4ef;
            --danger: #c0392b;
            --success: #2e9e6b;
            --radius: 12px;
            --ease: cubic-bezier(0.65, 0, 0.35, 1);
        }

        html, body {
            height: 100%;
            font-family: 'DM Sans', system-ui, sans-serif;
            background: var(--navy);
            overflow: hidden;
        }

        /* ── PAGE SHELL ── */
        .auth-shell {
            display: flex;
            height: 100vh;
            width: 100vw;
            position: relative;
            overflow: hidden;
        }

        /* ── LEFT PANEL — Dark Command Side ── */
        .auth-dark {
            flex: 1;
            background: linear-gradient(160deg, var(--navy) 0%, #0a1628 60%, #051020 100%);
            position: relative;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 48px 56px;
            z-index: 1;
            overflow: hidden;
            transition: flex 0.8s var(--ease);
        }

        /* Animated SVG circuit lines */
        .circuit-bg {
            position: absolute;
            inset: 0;
            pointer-events: none;
            opacity: 0.18;
        }

        .circuit-line {
            stroke: var(--teal);
            stroke-width: 1;
            fill: none;
            stroke-dasharray: 600;
            stroke-dashoffset: 600;
            animation: drawLine 3s var(--ease) forwards;
        }

            .circuit-line:nth-child(2) {
                animation-delay: 0.4s;
            }

            .circuit-line:nth-child(3) {
                animation-delay: 0.8s;
            }

            .circuit-line:nth-child(4) {
                animation-delay: 1.2s;
                stroke: var(--primary);
            }

            .circuit-line:nth-child(5) {
                animation-delay: 1.6s;
                stroke: var(--primary);
            }

        .circuit-dot {
            fill: var(--teal);
            animation: pulseDot 3s ease-in-out infinite;
        }

            .circuit-dot:nth-child(6) {
                animation-delay: 0.5s;
            }

            .circuit-dot:nth-child(7) {
                animation-delay: 1s;
                fill: var(--primary);
            }

            .circuit-dot:nth-child(8) {
                animation-delay: 1.5s;
            }

        @@keyframes drawLine {
            to {
                stroke-dashoffset: 0;
            }
        }

        @@keyframes pulseDot {
            0%, 100% {
                opacity: 0.3;
                r: 3;
            }

            50% {
                opacity: 1;
                r: 5;
            }
        }

        /* Radial glow */
        .auth-dark::before {
            content: '';
            position: absolute;
            bottom: -100px;
            left: -100px;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, var(--primary-glow) 0%, transparent 65%);
            pointer-events: none;
        }

        .auth-dark::after {
            content: '';
            position: absolute;
            top: -80px;
            right: -80px;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, var(--teal-dim) 0%, transparent 65%);
            pointer-events: none;
        }

        /* Brand */
        .auth-brand {
            position: relative;
            z-index: 2;
        }

        .auth-brand-logo {
            font-family: 'Syne', sans-serif;
            font-size: 1.75rem;
            font-weight: 800;
            color: #fff;
            letter-spacing: -0.5px;
            text-decoration: none;
            display: inline-block;
            animation: fadeUp 0.6s var(--ease) both;
        }

            .auth-brand-logo span {
                color: var(--teal);
            }

        .auth-brand-tagline {
            font-size: 0.72rem;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 2.5px;
            color: rgba(255,255,255,0.35);
            margin-top: 5px;
            animation: fadeUp 0.6s 0.1s var(--ease) both;
        }

        /* Hero copy */
        .auth-hero {
            position: relative;
            z-index: 2;
            animation: fadeUp 0.7s 0.3s var(--ease) both;
        }

        .auth-hero-eyebrow {
            font-size: 0.72rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: var(--teal);
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .auth-hero-eyebrow::before {
                content: '';
                display: block;
                width: 28px;
                height: 1.5px;
                background: var(--teal);
            }

        .auth-hero-title {
            font-family: 'Syne', sans-serif;
            font-size: clamp(2rem, 3.5vw, 3rem);
            font-weight: 800;
            color: #fff;
            letter-spacing: -1px;
            margin-bottom: 20px;
        }

            .auth-hero-title em {
                font-style: normal;
                color: var(--teal);
            }

        .auth-hero-desc {
            font-size: 0.9rem;
            color: rgba(255,255,255,0.5);
            line-height: 1.7;
            max-width: 340px;
        }

        /* Feature pills */
        .auth-features {
            position: relative;
            z-index: 2;
            display: flex;
            flex-direction: column;
            gap: 10px;
            animation: fadeUp 0.7s 0.5s var(--ease) both;
        }

        .auth-feature {
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 0.82rem;
            color: rgba(255,255,255,0.6);
        }

        .auth-feature-icon {
            width: 28px;
            height: 28px;
            border-radius: 8px;
            background: rgba(4,196,217,0.12);
            border: 1px solid rgba(4,196,217,0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.75rem;
            color: var(--teal);
            flex-shrink: 0;
        }

        /* ── RIGHT PANEL — Light Form Side ── */
        .auth-light {
            width: 480px;
            min-width: 420px;
            background: var(--surface);
            position: relative;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 56px 52px;
            z-index: 2;
            box-shadow: -24px 0 80px rgba(0,0,0,0.35);
            transition: transform 0.8s var(--ease);
            overflow-y: auto;
        }

            /* Subtle top accent line */
            .auth-light::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 3px;
                background: linear-gradient(90deg, var(--primary), var(--teal));
            }

        /* ── FORM PANEL SWITCHER ── */
        .auth-panels {
            position: relative;
            width: 100%;
        }

        .auth-panel {
            width: 100%;
            transition: opacity 0.45s var(--ease), transform 0.45s var(--ease);
        }

            .auth-panel.hidden {
                position: absolute;
                top: 0;
                left: 0;
                opacity: 0;
                pointer-events: none;
                transform: translateX(24px);
            }

            .auth-panel.visible {
                opacity: 1;
                transform: translateX(0);
            }

        /* ── PANEL HEADER ── */
        .auth-panel-heading {
            margin-bottom: 32px;
        }

        .auth-panel-label {
            font-size: 0.72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: var(--primary);
            margin-bottom: 8px;
        }

        .auth-panel-title {
            font-family: 'Syne', sans-serif;
            font-size: 1.8rem;
            font-weight: 800;
            color: var(--text);
            letter-spacing: -0.5px;
            line-height: 1.1;
        }

        .auth-panel-sub {
            font-size: 0.85rem;
            color: var(--muted);
            margin-top: 6px;
        }

        /* ── FORM FIELDS ── */
        .auth-field {
            margin-bottom: 18px;
            position: relative;
        }

            .auth-field label {
                display: block;
                font-size: 0.78rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.8px;
                color: var(--text);
                margin-bottom: 7px;
            }

        .auth-input-wrap {
            position: relative;
            display: flex;
            align-items: center;
        }

        .auth-input-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 0.8rem;
            color: var(--muted);
            pointer-events: none;
            z-index: 3;
            transition: color 0.2s ease;
        }

        .auth-input {
            width: 100%;
            height: 48px;
            padding: 0 16px 0 42px;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.9rem;
            color: var(--text) !important;
            background: var(--bg-light);
            border: 1.5px solid var(--border);
            border-radius: 10px;
            outline: none;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
            -webkit-text-fill-color: var(--text) !important;
        }

            /* Autofill override */
            .auth-input:-webkit-autofill,
            .auth-input:-webkit-autofill:hover,
            .auth-input:-webkit-autofill:focus,
            .auth-input:-webkit-autofill:active {
                -webkit-box-shadow: 0 0 0 60px var(--bg-light) inset !important;
                -webkit-text-fill-color: var(--text) !important;
                box-shadow: 0 0 0 60px var(--bg-light) inset !important;
                caret-color: var(--text) !important;
                padding-left: 42px !important;
                font-family: 'DM Sans', sans-serif !important;
                font-size: 0.9rem !important;
                transition: background-color 9999s ease-in-out 0s, padding 0s !important;
            }

            .auth-input:focus {
                border-color: var(--primary);
                background: var(--surface);
                box-shadow: 0 0 0 3px rgba(4,119,191,0.12);
            }

                .auth-input:focus:-webkit-autofill {
                    -webkit-box-shadow: 0 0 0 60px var(--surface) inset !important;
                }

        .auth-input-wrap:focus-within .auth-input-icon {
            color: var(--primary);
        }

        .auth-input:focus + .auth-input-icon,
        .auth-input-wrap:focus-within .auth-input-icon {
            color: var(--primary);
        }

        /* Validation error state */
        .auth-input.is-error {
            border-color: var(--danger);
            background: #fdf0ee;
        }

            .auth-input.is-error:-webkit-autofill,
            .auth-input.is-error:-webkit-autofill:focus {
                -webkit-box-shadow: 0 0 0 60px #fdf0ee inset !important;
            }

        .auth-error-msg {
            font-size: 0.775rem;
            color: var(--danger);
            font-weight: 500;
            margin-top: 5px;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        /* Validation summary */
        .auth-validation-summary {
            background: #fdf0ee;
            border: 1.5px solid rgba(192,57,43,0.2);
            border-left: 4px solid var(--danger);
            border-radius: 8px;
            padding: 12px 14px;
            margin-bottom: 20px;
            font-size: 0.825rem;
            color: var(--danger);
        }

            .auth-validation-summary ul {
                margin: 4px 0 0 16px;
                padding: 0;
            }

        /* ── SUBMIT BUTTON ── */
        .auth-btn {
            width: 100%;
            height: 50px;
            background: linear-gradient(135deg, var(--primary) 0%, #0560a0 100%);
            color: #fff;
            border: none;
            border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.9rem;
            font-weight: 700;
            letter-spacing: 0.3px;
            cursor: pointer;
            transition: all 0.25s ease;
            position: relative;
            overflow: hidden;
            margin-top: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

            .auth-btn::before {
                content: '';
                position: absolute;
                inset: 0;
                background: linear-gradient(135deg, var(--teal) 0%, var(--primary) 100%);
                opacity: 0;
                transition: opacity 0.3s ease;
            }

            .auth-btn:hover::before {
                opacity: 1;
            }

            .auth-btn:hover {
                transform: translateY(-1px);
                box-shadow: 0 8px 24px rgba(4,119,191,0.35);
            }

            .auth-btn:active {
                transform: translateY(0);
            }

            .auth-btn span {
                position: relative;
                z-index: 1;
            }

            .auth-btn i {
                position: relative;
                z-index: 1;
            }

        /* ── SWITCH LINK ── */
        .auth-switch {
            text-align: center;
            margin-top: 24px;
            font-size: 0.85rem;
            color: var(--muted);
        }

            .auth-switch a {
                color: var(--primary);
                font-weight: 700;
                text-decoration: none;
                cursor: pointer;
                transition: color 0.2s ease;
            }

                .auth-switch a:hover {
                    color: var(--teal);
                }

        /* ── DIVIDER ── */
        .auth-divider {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 20px 0;
            font-size: 0.75rem;
            color: var(--muted);
        }

            .auth-divider::before,
            .auth-divider::after {
                content: '';
                flex: 1;
                height: 1px;
                background: var(--border);
            }

        /* ── FORGOT PASSWORD ── */
        .auth-forgot {
            text-align: right;
            margin-top: -10px;
            margin-bottom: 16px;
        }

            .auth-forgot a {
                font-size: 0.78rem;
                color: var(--muted);
                text-decoration: none;
                transition: color 0.2s ease;
            }

                .auth-forgot a:hover {
                    color: var(--primary);
                }

        /* ── FOOTER ── */
        .auth-footer {
            position: absolute;
            bottom: 24px;
            left: 52px;
            right: 52px;
            text-align: center;
            font-size: 0.72rem;
            color: var(--muted);
        }

        /* ── ANIMATIONS ── */
        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(16px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .auth-light {
            animation: fadeUp 0.5s 0.1s var(--ease) both;
        }

        /* ── RESPONSIVE ── */
        @@media (max-width: 800px) {
            .auth-dark {
                display: none;
            }

            .auth-light {
                width: 100%;
                min-width: unset;
                box-shadow: none;
                padding: 40px 28px;
            }
        }
    </style>
</head>
<body>

    <div class="auth-shell">

        <!-- ── LEFT: Dark command panel ── -->
        <div class="auth-dark">

            <!-- Animated circuit SVG -->
            <svg class="circuit-bg" viewBox="0 0 600 700" preserveAspectRatio="xMidYMid slice">
                <!-- Horizontal traces -->
                <path class="circuit-line" d="M 0 120 H 200 V 200 H 350 V 140 H 550" />
                <path class="circuit-line" d="M 0 300 H 100 V 380 H 300 V 320 H 600" />
                <path class="circuit-line" d="M 50 500 H 250 V 560 H 500 V 480 H 600" />
                <!-- Vertical traces -->
                <path class="circuit-line" d="M 450 0 V 140 H 380 V 320 H 450 V 480 H 400 V 600" />
                <path class="circuit-line" d="M 150 0 V 200 H 220 V 380 H 160 V 560 H 200 V 700" />
                <!-- Dots -->
                <circle class="circuit-dot" cx="200" cy="120" r="4" />
                <circle class="circuit-dot" cx="350" cy="200" r="4" />
                <circle class="circuit-dot" cx="300" cy="380" r="4" />
                <circle class="circuit-dot" cx="450" cy="140" r="4" />
                <circle class="circuit-dot" cx="250" cy="560" r="4" />
            </svg>

            <!-- Brand -->
            <div class="auth-brand">
                <div class="auth-brand-logo">Tech<span>Solutions</span></div>
                <div class="auth-brand-tagline">Customer Management System</div>
            </div>

            <!-- Hero copy -->
            <div class="auth-hero">
                <div class="auth-hero-eyebrow">Secure Platform</div>
                <h1 class="auth-hero-title">
                    Manage with<br><em>precision</em><br>and care.
                </h1>
                <p class="auth-hero-desc">
                    A unified system for healthcare and technology professionals to manage customer data with integrity and compliance.
                </p>
            </div>

            <!-- Feature list -->
            <div class="auth-features">
                <div class="auth-feature">
                    <div class="auth-feature-icon"><i class="fa-solid fa-shield-halved"></i></div>
                    <span>AES-256 encrypted sensitive data</span>
                </div>
                <div class="auth-feature">
                    <div class="auth-feature-icon"><i class="fa-solid fa-chart-line"></i></div>
                    <span>Real-time data quality scoring</span>
                </div>
                <div class="auth-feature">
                    <div class="auth-feature-icon"><i class="fa-solid fa-lock"></i></div>
                    <span>Role-based access control</span>
                </div>
            </div>
        </div>

        <!-- ── RIGHT: Form panel ── -->
        <div class="auth-light">

            <div class="auth-panels">

                <!-- LOGIN PANEL -->
                <div class="auth-panel visible" id="loginPanel">
                    <div class="auth-panel-heading">
                        <div class="auth-panel-label">Welcome back</div>
                        <h2 class="auth-panel-title">Sign in</h2>
                        <p class="auth-panel-sub">Enter your credentials to access the system</p>
                    </div>

                    @using (Html.BeginForm("Login", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        if (!ViewData.ModelState.IsValid)
                        {
                            <div class="auth-validation-summary">
                                <strong><i class="fa-solid fa-triangle-exclamation"></i> Sign-in failed</strong>
                                <ul>
                                    @foreach (var error in ViewData.ModelState
                                                  .Where(x => x.Value.Errors.Any())
                                                  .SelectMany(x => x.Value.Errors))
                                    {
                                        <li>@error.ErrorMessage</li>
                                    }
                                </ul>
                            </div>
                        }

                        <div class="auth-field">
                            <label for="login-email">Email Address</label>
                            <div class="auth-input-wrap">
                                <input type="email"
                                       id="login-email"
                                       name="Email"
                                       class="auth-input"
                                       placeholder="you@example.com"
                                       autocomplete="email"
                                       value="@(ViewBag.LoginEmail ?? "")" />
                                <i class="fa-regular fa-envelope auth-input-icon"></i>
                            </div>
                        </div>

                        <div class="auth-field">
                            <label for="login-password">Password</label>
                            <div class="auth-input-wrap">
                                <input type="password"
                                       id="login-password"
                                       name="Password"
                                       class="auth-input"
                                       placeholder="••••••••"
                                       autocomplete="current-password" />
                                <i class="fa-solid fa-lock auth-input-icon"></i>
                            </div>
                        </div>

                        <div class="auth-forgot">
                            <a href="#">Forgot password?</a>
                        </div>

                        <div style="display:flex;align-items:center;gap:10px;margin-bottom:20px;">
                            @Html.CheckBoxFor(m => m.RememberMe,new { style = "width:16px;height:16px;accent-color:var(--primary);cursor:pointer;" })
                            <label for="RememberMe" style="font-size:0.83rem;color:var(--muted);cursor:pointer;font-weight:400;margin:0;">
                                Remember Me
                            </label>
                        </div>

                        <button type="submit" class="auth-btn">
                            <span>Sign In</span>
                            <i class="fa-solid fa-arrow-right"></i>
                        </button>
                    }

                    <div class="auth-switch">
                        Don't have an account?
                        <a onclick="switchPanel('register')">Create one</a>
                    </div>
                </div>

                <!-- REGISTER PANEL -->
                <div class="auth-panel hidden" id="registerPanel">
                    <div class="auth-panel-heading">
                        <div class="auth-panel-label">New account</div>
                        <h2 class="auth-panel-title">Register</h2>
                        <p class="auth-panel-sub">Create your TechSolutions account</p>
                    </div>
                    @using (Html.BeginForm("Register", "Account", FormMethod.Post, new { id = "registerForm", novalidate = "novalidate" }))
                    {
                        @Html.AntiForgeryToken()
                        if (!ViewData.ModelState.IsValid && ViewBag.RegisterAttempt == true)
                        {
                            <div class="auth-validation-summary">
                                <strong><i class="fa-solid fa-triangle-exclamation"></i> Registration failed</strong>
                                @Html.ValidationSummary(false)
                            </div>
                        }

                        <div style="display:flex;gap:12px;">
                            <div class="auth-field" style="flex:1;">
                                <label>First Name</label>
                                <div class="auth-input-wrap">
                                    <input type="text" name="FirstName" class="auth-input"
                                           placeholder="Jane" autocomplete="given-name" />
                                    <i class="fa-solid fa-user auth-input-icon"></i>
                                </div>
                            </div>
                            <div class="auth-field" style="flex:1;">
                                <label>Last Name</label>
                                <div class="auth-input-wrap">
                                    <input type="text" name="LastName" class="auth-input"
                                           placeholder="Smith" autocomplete="family-name" />
                                    <i class="fa-solid fa-user auth-input-icon"></i>
                                </div>
                            </div>
                        </div>

                        <div class="auth-field">
                            <label>Email Address</label>
                            <div class="auth-input-wrap">
                                <input type="email" name="Email" class="auth-input"
                                       placeholder="you@example.com" autocomplete="email" />
                                <i class="fa-regular fa-envelope auth-input-icon"></i>
                            </div>
                        </div>

                        <div class="auth-field">
                            <label>Password</label>
                            <div class="auth-input-wrap">
                                <input type="password" name="Password" class="auth-input"
                                       placeholder="Min. 8 characters" autocomplete="new-password" id="reg-password" />
                                <i class="fa-solid fa-lock auth-input-icon"></i>
                            </div>

                            <!-- Password strength bar -->
                            <div style="display:flex;flex-direction:column;align-items:center;gap:6px;margin-top:8px;">
                                <div style="width:100%;height:4px;background:var(--border);border-radius:4px;overflow:hidden;">
                                    <div class="pw-strength-fill" id="pwFill" style="height:100%;width:0%;border-radius:4px;transition:width 0.3s ease,background 0.3s ease;"></div>
                                </div>
                                <span class="pw-strength-label" id="pwLabel" style="font-size:0.72rem;font-weight:700;color:var(--muted);"></span>
                            </div>
                        </div>

                        <div class="auth-field">
                            <label>Confirm Password</label>
                            <div class="auth-input-wrap">
                                <input type="password" name="ConfirmPassword" class="auth-input"
                                       placeholder="Repeat password" autocomplete="new-password" />
                                <i class="fa-solid fa-lock auth-input-icon"></i>
                            </div>
                        </div>

                        <button type="submit" class="auth-btn">
                            <span>Create Account</span>
                            <i class="fa-solid fa-arrow-right"></i>
                        </button>
                    }

                    <div class="auth-switch">
                        Already have an account?
                        <a onclick="switchPanel('login')">Sign in</a>
                    </div>
                </div>
            </div>

            <div class="auth-footer">
                &copy; @DateTime.Now.Year TechSolutions &mdash; All data encrypted &amp; secure
            </div>
        </div>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")

    <script>


        // ── Panel switch with smooth transition ──
        function switchPanel(target) {
            var loginPanel = document.getElementById('loginPanel');
            var registerPanel = document.getElementById('registerPanel');

            if (target === 'register') {
                loginPanel.classList.remove('visible');
                loginPanel.classList.add('hidden');
                registerPanel.classList.remove('hidden');
                registerPanel.classList.add('visible');
                // Slide panel from left direction when going to register
                registerPanel.style.transform = 'translateX(-24px)';
                setTimeout(function () { registerPanel.style.transform = 'translateX(0)'; }, 10);
            } else {
                registerPanel.classList.remove('visible');
                registerPanel.classList.add('hidden');
                loginPanel.classList.remove('hidden');
                loginPanel.classList.add('visible');
                loginPanel.style.transform = 'translateX(24px)';
                setTimeout(function () { loginPanel.style.transform = 'translateX(0)'; }, 10);
            }
        }

        // ── Password strength meter ──
        document.getElementById('reg-password').addEventListener('input', function () {
            var val = this.value;
            var fill = document.getElementById('pwFill');
            var lbl = document.getElementById('pwLabel');
            var score = 0;

            if (val.length >= 8) score++;
            if (/[A-Z]/.test(val)) score++;
            if (/[0-9]/.test(val)) score++;
            if (/[^A-Za-z0-9]/.test(val)) score++;

            var configs = [
                { pct: '0%', color: 'var(--border)', text: '' },
                { pct: '25%', color: 'var(--danger)', text: 'Weak' },
                { pct: '50%', color: 'var(--color-warning, #d48e10)', text: 'Fair' },
                { pct: '75%', color: 'var(--primary)', text: 'Good' },
                { pct: '100%', color: 'var(--success)', text: 'Strong' }
            ];

            var cfg = val.length === 0 ? configs[0] : configs[score];
            fill.style.width = cfg.pct;
            fill.style.background = cfg.color;
            lbl.textContent = cfg.text;
            lbl.style.color = cfg.color;
        });

        // ── Real-time input validation feedback ──
        document.querySelectorAll('.auth-input').forEach(function (input) {
            input.addEventListener('blur', function () {
                if (this.value.trim() === '' && this.hasAttribute('required')) {
                    this.classList.add('is-error');
                } else {
                    this.classList.remove('is-error');
                }
            });
            input.addEventListener('input', function () {
                this.classList.remove('is-error');
            });
        });

        // ── Autofill padding fix ──
        // Force padding-left on every input inside a wrap so the icon
        // never overlaps — CSS alone fails for hidden panels during autofill.
        function enforceInputPadding() {
            document.querySelectorAll('.auth-input-wrap .auth-input').forEach(function (el) {
                el.style.setProperty('padding-left', '42px', 'important');
                el.style.setProperty('font-family', "'DM Sans', sans-serif", 'important');
                el.style.setProperty('font-size', '0.9rem', 'important');
                el.style.setProperty('-webkit-text-fill-color', 'var(--text)', 'important');
            });
        }

        // Run immediately, then poll for 5s to catch late browser autofill
        enforceInputPadding();
        var _tick = 0;
        var _poll = setInterval(function () {
            enforceInputPadding();
            if (++_tick >= 100) clearInterval(_poll);
        }, 50);

        // Re-run after panel switch
        var _origSwitch = switchPanel;
        switchPanel = function (target) {
            _origSwitch(target);
            setTimeout(enforceInputPadding, 50);
            setTimeout(enforceInputPadding, 400);
        };

         @if (ViewBag.RegisterAttempt == true)
     {
         <text>switchPanel('register');</text>
     }
    </script>

</body>
</html>
