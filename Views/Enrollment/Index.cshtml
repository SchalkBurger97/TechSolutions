@model List<TechSolutions.Models.EnrollmentHistory>

@{
    ViewBag.Title = "Course Enrollments";
    var customer = ViewBag.Customer as TechSolutions.Models.Customer;
}

<!-- Toast Notifications -->
@if (TempData["SuccessMessage"] != null || TempData["ErrorMessage"] != null)
{
    <div id="toastContainer" style="position:fixed;top:80px;right:20px;z-index:9999;min-width:340px;max-width:480px;">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="app-toast alert alert-success" role="alert">
                <strong><i class="fa-solid fa-circle-check"></i> Success</strong>
                <p class="mb-0 mt-1" style="font-size:0.825rem;">@TempData["SuccessMessage"]</p>
                <button class="app-toast-close" style="position:absolute;top:10px;right:12px;background:none;border:none;font-size:1.2rem;cursor:pointer;color:inherit;opacity:0.6;">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="app-toast app-toast-error alert alert-danger" role="alert">
                <strong><i class="fa-solid fa-triangle-exclamation"></i> Error</strong>
                <p class="mb-0 mt-1" style="font-size:0.825rem;">@TempData["ErrorMessage"]</p>
                <button class="app-toast-close" style="position:absolute;top:10px;right:12px;background:none;border:none;font-size:1.2rem;cursor:pointer;color:inherit;opacity:0.6;">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
        }
    </div>
}

<!-- Page Header -->
<div class="page-header">
    <div>
        <h2><i class="fa-solid fa-graduation-cap"></i> Course Enrollments</h2>
        <span class="text-muted" style="font-size:0.875rem;">
            @customer.FullName &mdash; <span class="customer-code">@customer.CustomerCode</span>
        </span>
    </div>
    <div style="display:flex;gap:8px;align-items:center;">
        <a href="@Url.Action("Details", "Customer", new { id = customer.CustomerID })" class="btn btn-default">
            <i class="fa-solid fa-arrow-left"></i> Back to Profile
        </a>
        <a href="@Url.Action("Create", new { customerId = customer.CustomerID })" class="btn btn-primary">
            <i class="fa-solid fa-plus"></i> Enroll in Course
        </a>
    </div>
</div>

<!-- Summary Stats -->
<div class="row g-3 mb-4">
    <div class="col-sm-3">
        <div class="stat-card stat-card-primary">
            <div class="stat-card-label">Total Enrollments</div>
            <div class="stat-card-value stat-card-value-md">@ViewBag.TotalEnrollments</div>
            <i class="fa-solid fa-list card-icon"></i>
        </div>
    </div>
    <div class="col-sm-3">
        <div class="stat-card stat-card-success">
            <div class="stat-card-label">Active Courses</div>
            <div class="stat-card-value stat-card-value-md">@ViewBag.ActiveEnrollments</div>
            <i class="fa-solid fa-book-open card-icon"></i>
        </div>
    </div>
    <div class="col-sm-3">
        <div class="stat-card stat-card-info">
            <div class="stat-card-label">Completed</div>
            <div class="stat-card-value stat-card-value-md">@ViewBag.CompletedEnrollments</div>
            <i class="fa-solid fa-circle-check card-icon"></i>
        </div>
    </div>
    <div class="col-sm-3">
        <div class="stat-card stat-card-warning">
            <div class="stat-card-label">Outstanding Balance</div>
            <div class="stat-card-value stat-card-value-sm">
                R @ViewBag.OutstandingBalance.ToString("N2")
            </div>
            <i class="fa-solid fa-circle-exclamation card-icon"></i>
        </div>
    </div>
</div>

<!-- Enrollments Table -->
<div class="content-card">
    <div class="content-card-header d-flex align-items-center justify-content-between">
        <h4 class="mb-0"><i class="fa-solid fa-book"></i> Enrollment History</h4>
        <span class="text-muted" style="font-size:0.8rem;font-weight:500;">
            @Model.Count enrollment@(Model.Count == 1 ? "" : "s")
        </span>
    </div>
    <div class="content-card-body p-0">
        @if (Model.Count > 0)
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Course</th>
                            <th>Enrolled</th>
                            <th>Duration</th>
                            <th>Fee</th>
                            <th>Payment</th>
                            <th>Status</th>
                            <th style="text-align:center;">Cert</th>
                            <th style="width:130px;text-align:center;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var enrollment in Model)
                        {
                            string statusVariant = enrollment.EnrollmentStatus == "Active" ? "success" :
                                                   enrollment.EnrollmentStatus == "Completed" ? "info" :
                                                   enrollment.EnrollmentStatus == "Withdrawn" ? "danger" :
                                                   enrollment.EnrollmentStatus == "Deferred" ? "warning" : "default";

                            string paymentVariant = enrollment.PaymentStatus == "Paid" ? "success" :
                                                    enrollment.PaymentStatus == "Partial" ? "warning" :
                                                    enrollment.PaymentStatus == "Pending" ? "danger" :
                                                    enrollment.PaymentStatus == "Refunded" ? "info" : "default";

                            <tr>
                                <td>
                                    <div style="font-weight:600;color:var(--color-primary);">
                                        @enrollment.CourseName
                                    </div>
                                    @if (!string.IsNullOrEmpty(enrollment.CourseCode))
                                    {
                                        <div class="customer-code mt-1">@enrollment.CourseCode</div>
                                    }
                                </td>
                                <td style="font-size:0.85rem;">
                                    @enrollment.EnrollmentDate.ToString("dd MMM yyyy")
                                </td>
                                <td>
                                    @if (enrollment.CourseStartDate.HasValue && enrollment.CourseEndDate.HasValue)
                                    {
                                        <div style="font-size:0.8rem;line-height:1.6;">
                                            <span>@enrollment.CourseStartDate.Value.ToString("dd MMM yyyy")</span><br />
                                            <span class="text-muted">to @enrollment.CourseEndDate.Value.ToString("dd MMM yyyy")</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic" style="font-size:0.8rem;">Not scheduled</span>
                                    }
                                </td>
                                <td>
                                    <strong>R @enrollment.CourseFee.ToString("N2")</strong>
                                </td>
                                <td>
                                    <div style="font-size:0.78rem;color:var(--color-muted);margin-bottom:4px;">
                                        R @enrollment.AmountPaid.ToString("N2") / R @enrollment.CourseFee.ToString("N2")
                                    </div>
                                    <span class="badge badge-@paymentVariant">@enrollment.PaymentStatus</span>
                                </td>
                                <td>
                                    <span class="badge badge-@statusVariant">@enrollment.EnrollmentStatus</span>
                                    @if (enrollment.EnrollmentStatus == "Completed" && enrollment.CompletionDate.HasValue)
                                    {
                                        <div style="font-size:0.75rem;color:var(--color-muted);margin-top:4px;">
                                            @enrollment.CompletionDate.Value.ToString("dd MMM yyyy")
                                        </div>
                                    }
                                </td>
                                <td style="text-align:center;">
                                    @if (enrollment.CertificateIssued)
                                    {
                                        <span title="Certificate issued @enrollment.CertificateIssueDate?.ToString(" dd MMM yyyy")">
                                            <i class="fa-solid fa-certificate" style="color:var(--color-warning);font-size:1.1rem;"></i>
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>
                                    <div class="table-actions">
                                        <a href="@Url.Action("Edit", new { id = enrollment.EnrollmentID })"
                                           class="table-action-btn" title="Edit">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </a>
                                        <button type="button"
                                                class="table-action-btn table-action-danger" title="Delete"
                                                onclick="confirmDelete(@enrollment.EnrollmentID, '@enrollment.CourseName.Replace("'", "\\'")', @customer.CustomerID)">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="fa-solid fa-graduation-cap empty-state-icon"></i>
                <h5>No enrollments yet</h5>
                <p>This customer has not been enrolled in any courses.</p>
                <a href="@Url.Action("Create", new { customerId = customer.CustomerID })" class="btn btn-primary">
                    <i class="fa-solid fa-plus"></i> Enroll in Course
                </a>
            </div>
        }
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:var(--radius-md);border:1px solid var(--color-border);overflow:hidden;">
            <div class="modal-header" style="background:var(--color-danger-bg);border-bottom:1px solid rgba(192,57,43,0.2);padding:16px 20px;">
                <h5 class="modal-title" style="color:var(--color-danger);font-weight:600;margin:0;">
                    <i class="fa-solid fa-triangle-exclamation"></i> Confirm Delete
                </h5>
            </div>
            <div class="modal-body" style="padding:20px;">
                <p id="deleteMessage" class="mb-0" style="font-size:0.9rem;"></p>
            </div>
            <div class="modal-footer" style="padding:12px 20px;border-top:1px solid var(--color-border);gap:8px;">
                <button type="button" class="btn btn-default" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">
                    <i class="fa-solid fa-trash"></i> Delete
                </button>
            </div>
        </div>
    </div>
</div>

<form id="deleteForm" method="post" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="customerId" id="deleteCustomerId" />
</form>

@section Scripts {
    <style>
        /* Shared table utilities */
        .table-actions {
            display: flex;
            gap: 4px;
            justify-content: center;
        }

        .table-action-btn {
            width: 30px;
            height: 30px;
            border-radius: var(--radius-sm);
            border: 1.5px solid var(--color-border);
            background: var(--color-surface);
            color: var(--color-muted);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 0.8rem;
            cursor: pointer;
            transition: var(--transition);
            text-decoration: none;
        }

            .table-action-btn:hover {
                background: var(--color-primary-light);
                border-color: var(--color-primary);
                color: var(--color-primary);
                transform: translateY(-1px);
            }

        .table-action-danger:hover {
            background: var(--color-danger-bg);
            border-color: var(--color-danger);
            color: var(--color-danger);
        }

        .customer-code {
            font-family: var(--font-mono);
            font-size: 0.78rem;
            background: var(--color-primary-light);
            color: var(--color-primary);
            padding: 1px 7px;
            border-radius: var(--radius-pill);
            font-weight: 500;
            display: inline-block;
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: var(--color-muted);
        }

        .empty-state-icon {
            font-size: 3.5rem;
            opacity: 0.18;
            display: block;
            margin-bottom: 20px;
            color: var(--color-primary);
        }

        .empty-state h5 {
            color: var(--color-text);
            font-weight: 600;
            margin-bottom: 8px;
        }

        .empty-state p {
            font-size: 0.875rem;
            margin-bottom: 20px;
        }

        .app-toast {
            margin-bottom: 10px;
            position: relative;
        }
    </style>

    <script>
    function confirmDelete(enrollmentId, courseName, customerId) {
        document.getElementById('deleteMessage').textContent =
            'Are you sure you want to delete the enrollment for "' + courseName + '"? This action cannot be undone.';
        document.getElementById('deleteCustomerId').value = customerId;
        new bootstrap.Modal(document.getElementById('deleteModal')).show();

        document.getElementById('confirmDeleteBtn').onclick = function () {
            var form = document.getElementById('deleteForm');
            form.action = '@Url.Action("Delete", "Enrollment")' + '/' + enrollmentId;
            form.submit();
        };
    }

    // Toast auto-dismiss
    setTimeout(function () {
        document.querySelectorAll('.app-toast:not(.app-toast-error)').forEach(function (el) {
            el.style.transition = 'all 0.35s ease-in';
            el.style.opacity = '0'; el.style.transform = 'translateX(120%)';
            setTimeout(function () { el.remove(); }, 350);
        });
    }, 5000);

    document.querySelectorAll('.app-toast-close').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var t = this.closest('.app-toast');
            t.style.transition = 'all 0.3s ease-in';
            t.style.opacity = '0'; t.style.transform = 'translateX(120%)';
            setTimeout(function () { t.remove(); }, 300);
        });
    });
    </script>
}
