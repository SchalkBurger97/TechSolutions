@model TechSolutions.Models.ChangePasswordViewModel
@{
    ViewBag.Title = "Change Password";
}

<!-- Page Header -->
<div class="page-header">
    <div>
        <h2><i class="fa-solid fa-key"></i> Change Password</h2>
        <span class="text-muted" style="font-size:0.875rem;">
            Update your account password
        </span>
    </div>
    <a href="@Url.Action("Index", "Manage")" class="btn btn-default">
        <i class="fa-solid fa-arrow-left"></i> Back to Settings
    </a>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="content-card">
            <div class="content-card-header">
                <h4 class="mb-0"><i class="fa-solid fa-lock"></i> Update Password</h4>
            </div>
            <div class="content-card-body">

                @using (Html.BeginForm("ChangePassword", "Manage", FormMethod.Post, new { id = "changePasswordForm", novalidate = "novalidate" }))
                {
                    @Html.AntiForgeryToken()

                    if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger mb-4">
                            <strong><i class="fa-solid fa-triangle-exclamation"></i> Please fix the following:</strong>
                            @Html.ValidationSummary(false, "", new { @class = "mb-0 mt-2" })
                        </div>
                    }

                    <div class="form-section" style="border-bottom:none;margin-bottom:0;padding-bottom:0;">
                        <div class="form-group mb-3">
                            @Html.LabelFor(m => m.OldPassword, "Current Password", new { @class = "control-label" })
                            <div class="input-icon-wrap">
                                <i class="fa-solid fa-lock input-icon"></i>
                                @Html.PasswordFor(m => m.OldPassword, new
                                {
                                    @class = "form-control has-icon",
                                    placeholder = "Enter your current password",
                                    autocomplete = "current-password"
                                })
                            </div>
                            @Html.ValidationMessageFor(m => m.OldPassword, "", new { @class = "field-validation-error" })
                        </div>

                        <div class="form-group mb-3">
                            @Html.LabelFor(m => m.NewPassword, "New Password", new { @class = "control-label" })
                            <div class="input-icon-wrap">
                                <i class="fa-solid fa-lock input-icon"></i>
                                @Html.PasswordFor(m => m.NewPassword, new
                                {
                                    @class = "form-control has-icon",
                                    placeholder = "Min. 6 characters",
                                    autocomplete = "new-password",
                                    id = "newPassword"
                                })
                            </div>
                            @Html.ValidationMessageFor(m => m.NewPassword, "", new { @class = "field-validation-error" })
                            <!-- Password strength bar -->
                            <div style="display:flex;align-items:center;gap:10px;margin-top:7px;">
                                <div style="flex:1;height:4px;background:var(--color-border);border-radius:var(--radius-pill);overflow:hidden;">
                                    <div id="pwStrengthFill" style="height:100%;width:0%;border-radius:var(--radius-pill);transition:width 0.3s ease,background 0.3s ease;"></div>
                                </div>
                                <span id="pwStrengthLabel" style="font-size:0.72rem;font-weight:700;min-width:48px;text-align:right;color:var(--color-muted);"></span>
                            </div>
                        </div>

                        <div class="form-group mb-4">
                            @Html.LabelFor(m => m.ConfirmPassword, "Confirm New Password", new { @class = "control-label" })
                            <div class="input-icon-wrap">
                                <i class="fa-solid fa-lock input-icon"></i>
                                @Html.PasswordFor(m => m.ConfirmPassword, new
                                {
                                    @class = "form-control has-icon",
                                    placeholder = "Repeat new password",
                                    autocomplete = "new-password"
                                })
                            </div>
                            @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "field-validation-error" })
                        </div>
                    </div>

                    <div class="form-actions">
                        <a href="@Url.Action("Index", "Manage")" class="btn btn-default">
                            <i class="fa-solid fa-xmark"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="fa-solid fa-floppy-disk"></i> Change Password
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Tips card -->
    <div class="col-md-6">
        <div class="content-card">
            <div class="content-card-header">
                <h4 class="mb-0"><i class="fa-solid fa-circle-info"></i> Password Tips</h4>
            </div>
            <div class="content-card-body">
                <div class="password-tip">
                    <i class="fa-solid fa-circle-check" style="color:var(--color-success);"></i>
                    <span>At least 6 characters long</span>
                </div>
                <div class="password-tip">
                    <i class="fa-solid fa-circle-check" style="color:var(--color-success);"></i>
                    <span>Mix uppercase and lowercase letters</span>
                </div>
                <div class="password-tip">
                    <i class="fa-solid fa-circle-check" style="color:var(--color-success);"></i>
                    <span>Include at least one number</span>
                </div>
                <div class="password-tip">
                    <i class="fa-solid fa-circle-check" style="color:var(--color-success);"></i>
                    <span>Include a special character (e.g. ! @@ # $)</span>
                </div>
                <div class="password-tip">
                    <i class="fa-solid fa-circle-xmark" style="color:var(--color-danger);"></i>
                    <span>Avoid using your name or email address</span>
                </div>
                <div class="password-tip">
                    <i class="fa-solid fa-circle-xmark" style="color:var(--color-danger);"></i>
                    <span>Do not reuse a previous password</span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <style>
        .input-icon-wrap {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 13px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--color-muted);
            font-size: 0.85rem;
            pointer-events: none;
            z-index: 2;
        }

        .form-control.has-icon {
            padding-left: 36px !important;
        }

        .form-actions {
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            padding-top: 20px;
            margin-top: 20px;
            border-top: 1px solid var(--color-border);
        }

        .password-tip {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.85rem;
            color: var(--color-text);
            padding: 8px 0;
            border-bottom: 1px solid var(--color-border);
        }

            .password-tip:last-child {
                border-bottom: none;
            }
    </style>
    <script>
    document.getElementById('newPassword').addEventListener('input', function () {
        var val   = this.value;
        var fill  = document.getElementById('pwStrengthFill');
        var label = document.getElementById('pwStrengthLabel');
        var score = 0;
        if (val.length >= 6)             score++;
        if (/[A-Z]/.test(val))           score++;
        if (/[0-9]/.test(val))           score++;
        if (/[^A-Za-z0-9]/.test(val))   score++;
        var configs = [
            { pct: '0%',   color: 'var(--color-border)',  text: '' },
            { pct: '25%',  color: 'var(--color-danger)',  text: 'Weak' },
            { pct: '50%',  color: 'var(--color-warning)', text: 'Fair' },
            { pct: '75%',  color: 'var(--color-primary)', text: 'Good' },
            { pct: '100%', color: 'var(--color-success)', text: 'Strong' }
        ];
        var cfg = val.length === 0 ? configs[0] : configs[score];
        fill.style.width      = cfg.pct;
        fill.style.background = cfg.color;
        label.textContent     = cfg.text;
        label.style.color     = cfg.color;
    });
    </script>
}
