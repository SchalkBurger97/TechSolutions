@model IList<TechSolutions.Models.UserRolesListViewModel>

@{
    ViewBag.Title = "User Role Management";
}

<!-- Toast Notifications -->
@if (TempData["StatusMessage"] != null)
{
    <div id="toastContainer" style="position:fixed;top:80px;right:20px;z-index:9999;min-width:340px;max-width:480px;">
        <div class="app-toast alert alert-success" role="alert">
            <strong><i class="fa-solid fa-circle-check"></i> Success</strong>
            <p class="mb-0 mt-1" style="font-size:0.825rem;">@TempData["StatusMessage"]</p>
            <button class="app-toast-close" style="position:absolute;top:10px;right:12px;background:none;border:none;font-size:1.2rem;cursor:pointer;color:inherit;opacity:0.6;">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
    </div>
}

<!-- Page Header -->
<div class="page-header">
    <div>
        <h2><i class="fa-solid fa-users-gear"></i> User Role Management</h2>
        <span class="text-muted" style="font-size:0.875rem;">View and manage roles assigned to each system user</span>
    </div>
    <a href="@Url.Action("Index")" class="btn btn-default">
        <i class="fa-solid fa-arrow-left"></i> Back to Settings
    </a>
</div>

<!-- User Roles Card -->
<div class="content-card">
    <div class="content-card-header d-flex align-items-center justify-content-between">
        <h4 class="mb-0"><i class="fa-solid fa-shield-halved"></i> System Users</h4>
        <span class="text-muted" style="font-size:0.8rem;font-weight:500;">
            @Model.Count user@(Model.Count == 1 ? "" : "s")
        </span>
    </div>
    <div class="content-card-body" style="padding:0;">

        @if (Model.Count > 0)
        {
            <div class="table-responsive" style="border-radius:0;box-shadow:none;border:none;">
                <table class="table table-striped table-hover mb-0">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Email</th>
                            <th>Assigned Roles</th>
                            <th style="width:100px;text-align:center;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td>
                                    <div class="user-cell">
                                        <div class="user-avatar-sm">@user.Initials</div>
                                        <strong>@user.FullName</strong>
                                    </div>
                                </td>
                                <td>
                                    <span style="font-size:0.85rem;color:var(--color-muted);">@user.UserName</span>
                                </td>
                                <td>
                                    @if (user.Roles.Any())
                                    {
                                        foreach (var role in user.Roles)
                                        {
                                            <span class="badge badge-primary" style="margin-right:4px;">@role</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="badge badge-default">No roles</span>
                                    }
                                </td>
                                <td style="text-align:center;">
                                    <div class="table-actions" style="justify-content:center;">
                                        <a href="@Url.Action("AssignRoles", new { userId = user.UserId })"
                                           class="table-action-btn" title="Edit Roles">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div style="padding:12px 22px;border-top:1px solid var(--color-border);">
                <p class="text-muted mb-0" style="font-size:0.825rem;">
                    <i class="fa-solid fa-circle-info"></i>
                    Showing <strong>@Model.Count</strong> user@(Model.Count == 1 ? "" : "s") — click <i class="fa-solid fa-pen-to-square"></i> to edit a user's roles
                </p>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="fa-solid fa-users-slash empty-state-icon"></i>
                <h5>No users found</h5>
                <p>There are no user accounts in the system yet.</p>
            </div>
        }

    </div>
</div>

@section Scripts {
    <style>
        .user-cell {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .user-avatar-sm {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
            color: #fff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 0.72rem;
            font-weight: 700;
            flex-shrink: 0;
            letter-spacing: -0.5px;
            box-shadow: var(--shadow-xs);
        }

        /* Re-use customer index patterns */
        .table-actions {
            display: flex;
            gap: 4px;
            justify-content: center;
        }

        .table-action-btn {
            width: 30px;
            height: 30px;
            border-radius: var(--radius-sm);
            border: 1.5px solid var(--color-border);
            background: var(--color-surface);
            color: var(--color-muted);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 0.8rem;
            cursor: pointer;
            transition: var(--transition);
            text-decoration: none;
        }

            .table-action-btn:hover {
                background: var(--color-primary-light);
                border-color: var(--color-primary);
                color: var(--color-primary);
                transform: translateY(-1px);
            }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: var(--color-muted);
        }

        .empty-state-icon {
            font-size: 3.5rem;
            opacity: 0.2;
            display: block;
            margin-bottom: 20px;
            color: var(--color-primary);
        }

        .empty-state h5 {
            color: var(--color-text);
            font-weight: 600;
            margin-bottom: 8px;
        }

        .empty-state p {
            font-size: 0.875rem;
            margin-bottom: 20px;
        }

        .app-toast {
            margin-bottom: 10px;
            position: relative;
        }
    </style>

    <script>
        // Auto-dismiss success toast after 5s
        setTimeout(function () {
            document.querySelectorAll('.app-toast').forEach(function (el) {
                el.style.transition = 'all 0.35s ease-in';
                el.style.opacity = '0';
                el.style.transform = 'translateX(120%)';
                setTimeout(function () { el.remove(); }, 350);
            });
        }, 5000);

        document.querySelectorAll('.app-toast-close').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var toast = this.closest('.app-toast');
                toast.style.transition = 'all 0.3s ease-in';
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(120%)';
                setTimeout(function () { toast.remove(); }, 300);
            });
        });
    </script>
}
