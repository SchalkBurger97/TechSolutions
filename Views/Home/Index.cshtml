@{
    ViewBag.Title = "Dashboard";

    int totalCustomers = ViewBag.TotalCustomers ?? 0;
    int newThisMonth = ViewBag.NewThisMonth ?? 0;
    decimal avgQuality = ViewBag.AverageQuality ?? 0m;
    int issuesCount = ViewBag.IssuesCount ?? 0;
    int activeEnrollments = ViewBag.ActiveEnrollments ?? 0;
    int completedThisMonth = ViewBag.CompletedThisMonth ?? 0;
    decimal outstandingTotal = ViewBag.OutstandingBalance ?? 0m;
    int expiredDocs = ViewBag.ExpiredDocuments ?? 0;
    int expiredPayments = ViewBag.ExpiredPayments ?? 0;
    int pendingClearances = ViewBag.PendingClearances ?? 0;
    int lowQualityCount = ViewBag.LowQualityCount ?? 0;
    int highRiskCount = ViewBag.HighRiskCount ?? 0;
    int highQualityCount = ViewBag.HighQualityCount ?? 0;
    int medQualityCount = ViewBag.MedQualityCount ?? 0;

    string qualityVariant = avgQuality >= 80 ? "success" : avgQuality >= 60 ? "warning" : "danger";
    string qualityIcon = avgQuality >= 80 ? "fa-circle-check" : avgQuality >= 60 ? "fa-circle-exclamation" : "fa-circle-xmark";
    bool hasCustomers = totalCustomers > 0;
    int totalUrgent = expiredDocs + expiredPayments + pendingClearances + lowQualityCount;
    int safeCount = Math.Max(0, totalCustomers - highRiskCount - issuesCount);
    int maxQ = Math.Max(Math.Max(highQualityCount, medQualityCount), Math.Max(lowQualityCount, 1));

    int complianceScore = totalUrgent == 0 ? 100 :
        (int)Math.Max(0, 100 - (totalUrgent * (100.0 / Math.Max(totalCustomers, 1))));
    string compVariant = complianceScore >= 80 ? "success" : complianceScore >= 60 ? "warning" : "danger";
}

<!-- Page Header -->
<div class="page-header">
    <div>
        <h2><i class="fa-solid fa-gauge-high"></i> Dashboard</h2>
        <span class="text-muted" style="font-size:0.875rem;">
            <i class="fa-regular fa-calendar"></i>
            @DateTime.Now.ToString("dddd, MMMM dd, yyyy")
        </span>
    </div>
    <a href="@Url.Action("Create", "Customer")" class="btn btn-primary">
        <i class="fa-solid fa-plus"></i> Add Customer
    </a>
</div>

@if (hasCustomers)
{
    <!-- ── Urgent Alert Banner ── -->
    if (totalUrgent > 0)
    {
        <div class="ops-alert-banner mb-4">
            <div class="ops-alert-icon"><i class="fa-solid fa-triangle-exclamation"></i></div>
            <div class="ops-alert-body">
                <strong>@totalUrgent item@(totalUrgent == 1 ? "" : "s") require your attention today</strong>
                <div class="ops-alert-chips">
                    @if (expiredDocs > 0)
                    {
                        <span class="ops-chip ops-chip-danger">
                            <i class="fa-solid fa-id-card"></i> @expiredDocs expired document@(expiredDocs == 1 ? "" : "s")
                        </span>
                    }
                    @if (expiredPayments > 0)
                    {
                        <span class="ops-chip ops-chip-danger">
                            <i class="fa-solid fa-credit-card"></i> @expiredPayments expired payment@(expiredPayments == 1 ? "" : "s")
                        </span>
                    }
                    @if (pendingClearances > 0)
                    {
                        <span class="ops-chip ops-chip-warning">
                            <i class="fa-solid fa-shield-halved"></i> @pendingClearances pending clearance@(pendingClearances == 1 ? "" : "s")
                        </span>
                    }
                    @if (lowQualityCount > 0)
                    {
                        <span class="ops-chip ops-chip-warning">
                            <i class="fa-solid fa-chart-bar"></i> @lowQualityCount low quality score@(lowQualityCount == 1 ? "" : "s")
                        </span>
                    }
                </div>
            </div>
            <a href="@Url.Action("Index", "Customer")" class="btn btn-sm btn-default ops-alert-cta">
                Review <i class="fa-solid fa-arrow-right"></i>
            </a>
        </div>
    }

    <!-- ── Row 1: Primary Metrics ── -->
    <div class="row g-3 mb-4">
        <div class="col-md-3 col-sm-6">
            <div class="stat-card stat-card-primary">
                <div class="stat-card-label">Total Customers</div>
                <div class="stat-card-value">@totalCustomers</div>
                <div class="stat-card-delta positive">
                    <i class="fa-solid fa-arrow-up"></i> @newThisMonth new this month
                </div>
                <i class="fa-solid fa-users card-icon"></i>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="stat-card stat-card-@qualityVariant">
                <div class="stat-card-label">Avg Data Quality</div>
                <div class="stat-card-value">@avgQuality<span style="font-size:1rem;font-weight:500;">%</span></div>
                <div class="stat-card-delta @(avgQuality >= 80 ? "positive" : "negative")">
                    <i class="fa-solid @qualityIcon"></i>
                    @(avgQuality >= 80 ? "Healthy" : avgQuality >= 60 ? "Needs work" : "Critical")
                </div>
                <i class="fa-solid fa-chart-line card-icon"></i>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="stat-card stat-card-info">
                <div class="stat-card-label">Active Enrollments</div>
                <div class="stat-card-value stat-card-value-md">@activeEnrollments</div>
                <div class="stat-card-delta positive">
                    <i class="fa-solid fa-circle-check"></i> @completedThisMonth completed this month
                </div>
                <i class="fa-solid fa-graduation-cap card-icon"></i>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="stat-card @(outstandingTotal > 0 ? "stat-card-warning" : "stat-card-success")">
                <div class="stat-card-label">Outstanding Balance</div>
                <div class="stat-card-value stat-card-value-sm">R @outstandingTotal.ToString("N0")</div>
                <div class="stat-card-delta @(outstandingTotal > 0 ? "negative" : "positive")">
                    <i class="fa-solid fa-@(outstandingTotal > 0 ? "circle-exclamation" : "circle-check")"></i>
                    @(outstandingTotal > 0 ? "Across all enrollments" : "All fees settled")
                </div>
                <i class="fa-solid fa-hand-holding-dollar card-icon"></i>
            </div>
        </div>
    </div>

    <!-- ── Row 2: Quick Actions + Compliance + Risk ── -->
    <div class="row g-3 mb-4">

        <!-- Quick Actions -->
        <div class="col-md-4">
            <div class="content-card h-100">
                <div class="content-card-header">
                    <h4 class="mb-0"><i class="fa-solid fa-bolt"></i> Quick Actions</h4>
                </div>
                <div class="content-card-body p-0">
                    <a href="@Url.Action("Create", "Customer")" class="quick-action-item">
                        <span class="quick-action-icon" style="color:var(--color-primary);"><i class="fa-solid fa-user-plus"></i></span>
                        <span class="quick-action-text">
                            <strong>Add New Customer</strong>
                            <small>Create a new customer record</small>
                        </span>
                        <i class="fa-solid fa-chevron-right quick-action-arrow"></i>
                    </a>
                    <a href="@Url.Action("Index", "Customer")" class="quick-action-item">
                        <span class="quick-action-icon" style="color:var(--color-secondary);"><i class="fa-solid fa-list"></i></span>
                        <span class="quick-action-text">
                            <strong>View All Customers</strong>
                            <small>Browse and manage records</small>
                        </span>
                        <i class="fa-solid fa-chevron-right quick-action-arrow"></i>
                    </a>
                    <a href="@Url.Action("Index", "DataQuality")" class="quick-action-item">
                        <span class="quick-action-icon" style="color:var(--color-success);"><i class="fa-solid fa-circle-check"></i></span>
                        <span class="quick-action-text">
                            <strong>System Data Overview</strong>
                            <small>Review integrity metrics</small>
                        </span>
                        <i class="fa-solid fa-chevron-right quick-action-arrow"></i>
                    </a>
                    <a href="@Url.Action("Index", "Reports")" class="quick-action-item" style="border-bottom:none;">
                        <span class="quick-action-icon" style="color:var(--color-warning);"><i class="fa-solid fa-file-lines"></i></span>
                        <span class="quick-action-text">
                            <strong>Report Portal</strong>
                            <small>Export and view system reports</small>
                        </span>
                        <i class="fa-solid fa-chevron-right quick-action-arrow"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Compliance Health -->
        <div class="col-md-4">
            <div class="content-card h-100">
                <div class="content-card-header">
                    <h4 class="mb-0"><i class="fa-solid fa-shield-halved"></i> Compliance Health</h4>
                </div>
                <div class="content-card-body">
                    <div class="compliance-item">
                        <div class="compliance-item-left">
                            <i class="fa-solid fa-id-card @(expiredDocs > 0 ? "text-danger" : "text-success")"></i>
                            <span>ID Documents</span>
                        </div>
                        <span class="badge badge-@(expiredDocs > 0 ? "danger" : "success")">
                            @(expiredDocs > 0 ? expiredDocs + " Expired" : "All Valid")
                        </span>
                    </div>
                    <div class="compliance-item">
                        <div class="compliance-item-left">
                            <i class="fa-solid fa-credit-card @(expiredPayments > 0 ? "text-danger" : "text-success")"></i>
                            <span>Payment Methods</span>
                        </div>
                        <span class="badge badge-@(expiredPayments > 0 ? "danger" : "success")">
                            @(expiredPayments > 0 ? expiredPayments + " Expired" : "All Valid")
                        </span>
                    </div>
                    <div class="compliance-item">
                        <div class="compliance-item-left">
                            <i class="fa-solid fa-shield-halved @(pendingClearances > 0 ? "text-warning" : "text-success")"></i>
                            <span>Medical Clearances</span>
                        </div>
                        <span class="badge badge-@(pendingClearances > 0 ? "warning" : "success")">
                            @(pendingClearances > 0 ? pendingClearances + " Pending" : "All Clear")
                        </span>
                    </div>
                    <div class="compliance-item" style="border-bottom:none;">
                        <div class="compliance-item-left">
                            <i class="fa-solid fa-chart-bar @(lowQualityCount > 0 ? "text-warning" : "text-success")"></i>
                            <span>Data Quality</span>
                        </div>
                        <span class="badge badge-@(lowQualityCount > 0 ? "warning" : "success")">
                            @(lowQualityCount > 0 ? lowQualityCount + " Below 60%" : "All Healthy")
                        </span>
                    </div>
                    <div class="compliance-overall mt-3">
                        <div class="compliance-overall-header">
                            <span style="font-size:0.75rem;font-weight:700;color:var(--color-muted);text-transform:uppercase;letter-spacing:0.5px;">Overall Compliance</span>
                            <span style="font-size:0.875rem;font-weight:700;color:var(--color-@compVariant);">@complianceScore%</span>
                        </div>
                        <div class="compliance-bar">
                            <div class="compliance-bar-fill compliance-fill-@compVariant" style="width:@complianceScore%"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Risk Donut -->
        <div class="col-md-4">
            <div class="content-card h-100">
                <div class="content-card-header">
                    <h4 class="mb-0"><i class="fa-solid fa-triangle-exclamation"></i> Risk Overview</h4>
                </div>
                <div class="content-card-body" style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:calc(100% - 53px);">
                    <div style="position:relative;width:160px;height:160px;">
                        <canvas id="riskDonut"></canvas>
                        <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center;pointer-events:none;">
                            <div style="font-size:1.4rem;font-weight:700;color:var(--color-text);line-height:1;">@totalCustomers</div>
                            <div style="font-size:0.7rem;color:var(--color-muted);">customers</div>
                        </div>
                    </div>
                    <div class="risk-legend" style="margin-top:20px;display:flex;flex-direction:column;gap:10px;width:100%;padding:0 22px;">
                        <div class="risk-legend-item">
                            <span class="risk-dot" style="background:#2e9e6b;"></span>
                            <span>Low Risk</span>
                            <strong>@safeCount</strong>
                        </div>
                        <div class="risk-legend-item">
                            <span class="risk-dot" style="background:#d48e10;"></span>
                            <span>Medium</span>
                            <strong>@issuesCount</strong>
                        </div>
                        <div class="risk-legend-item">
                            <span class="risk-dot" style="background:#c0392b;"></span>
                            <span>High Risk</span>
                            <strong>@highRiskCount</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Row 3: Recent Customers + Quality Distribution ── -->
    <div class="row g-3 mb-4">

        <div class="col-md-7">
            <div class="content-card">
                <div class="content-card-header d-flex align-items-center justify-content-between">
                    <h4 class="mb-0"><i class="fa-solid fa-clock-rotate-left"></i> Recently Added</h4>
                    <a href="@Url.Action("Index", "Customer")" style="font-size:0.8rem;color:var(--color-primary);font-weight:600;text-decoration:none;">
                        View all <i class="fa-solid fa-arrow-right"></i>
                    </a>
                </div>
                <div class="content-card-body p-0" style="display:flex;flex-direction:column;">
                    @if (ViewBag.RecentCustomers != null)
                    {
                        var recentList = ViewBag.RecentCustomers as List<TechSolutions.Models.Customer>;
                        foreach (var c in recentList)
                        {
                            string firstName = (string)(c.FirstName ?? "");
                            string lastName = (string)(c.LastName ?? "");
                            string ini = (firstName.Length > 0 ? firstName.Substring(0, 1) : "") +
                                               (lastName.Length > 0 ? lastName.Substring(0, 1) : "");
                            string qv = (decimal)c.DataQualityScore >= 80 ? "success" :
                                               (decimal)c.DataQualityScore >= 60 ? "warning" : "danger";
                            int daysAgo = (DateTime.Now - (DateTime)c.CreatedDate).Days;
                            <a href="@Url.Action("Details", "Customer", new { id = c.CustomerID })" class="recent-customer-row">
                                <div class="recent-customer-avatar">@ini</div>
                                <div class="recent-customer-info">
                                    <strong>@c.FullName</strong>
                                    <small>@c.CustomerCode &middot; @c.CustomerType</small>
                                </div>
                                <div class="recent-customer-meta">
                                    <span class="badge badge-@qv">@c.DataQualityScore%</span>
                                    <small class="text-muted">@(daysAgo == 0 ? "Today" : daysAgo + "d ago")</small>
                                </div>
                            </a>
                        }

                        // Pad with empty rows so the card always shows 5 rows
                        int padCount = 4 - recentList.Count;
                        for (int i = 0; i < padCount; i++)
                        {
                            <div class="recent-customer-row recent-customer-empty">
                                <div class="recent-customer-avatar recent-avatar-empty">
                                    <i class="fa-solid fa-user" style="opacity:0.25;font-size:0.9rem;"></i>
                                </div>
                                <div class="recent-customer-info">
                                    <span class="empty-row-line" style="width:@(120 + i * 20)px;"></span>
                                    <span class="empty-row-line" style="width:@(70 + i * 10)px;margin-top:4px;height:10px;"></span>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        for (int i = 0; i < 4; i++)
                        {
                            <div class="recent-customer-row recent-customer-empty">
                                <div class="recent-customer-avatar recent-avatar-empty">
                                    <i class="fa-solid fa-user" style="opacity:0.25;font-size:0.9rem;"></i>
                                </div>
                                <div class="recent-customer-info">
                                    <span class="empty-row-line" style="width:@(100 + i * 25)px;"></span>
                                    <span class="empty-row-line" style="width:@(60 + i * 12)px;margin-top:4px;height:10px;"></span>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="content-card h-100">
                <div class="content-card-header">
                    <h4 class="mb-0"><i class="fa-solid fa-chart-bar"></i> Quality Distribution</h4>
                </div>
                <div class="content-card-body">
                    <div class="quality-bars">
                        <div class="quality-bar-row">
                            <span class="quality-bar-label">80–100%</span>
                            <div class="quality-bar-track">
                                <div class="quality-bar-fill quality-fill-success" style="width:@(highQualityCount * 100 / maxQ)%"></div>
                            </div>
                            <span class="quality-bar-count">@highQualityCount</span>
                        </div>
                        <div class="quality-bar-row">
                            <span class="quality-bar-label">60–79%</span>
                            <div class="quality-bar-track">
                                <div class="quality-bar-fill quality-fill-warning" style="width:@(medQualityCount * 100 / maxQ)%"></div>
                            </div>
                            <span class="quality-bar-count">@medQualityCount</span>
                        </div>
                        <div class="quality-bar-row">
                            <span class="quality-bar-label">0–59%</span>
                            <div class="quality-bar-track">
                                <div class="quality-bar-fill quality-fill-danger" style="width:@(lowQualityCount * 100 / maxQ)%"></div>
                            </div>
                            <span class="quality-bar-count">@lowQualityCount</span>
                        </div>
                    </div>
                    <div class="quality-insight mt-4">
                        <i class="fa-solid fa-lightbulb"></i>
                        <span>
                            @if (lowQualityCount == 0 && medQualityCount == 0)
                            {
                                <text>All customers have excellent data quality.</text>
                            }
                            else if (lowQualityCount > 0)
                            {
                                <text><strong>@lowQualityCount customer@(lowQualityCount == 1 ? "" : "s")</strong> below 60% — edit their profiles to improve scores.</text>
                            }
                            else
                            {
                                <text><strong>@medQualityCount customer@(medQualityCount == 1 ? "" : "s")</strong> between 60–79% — completing missing fields will improve scores.</text>
                            }
                        </span>
                    </div>
                    <div class="mt-3 text-center">
                        @if (ViewBag.QualityReportId != null)
                        {
                            <a href="@Url.Action("Run", "Reports", new { id = ViewBag.QualityReportId, returnUrl = Url.Action("Index", "Home"), returnLabel = "Back to Dashboard" })" class="btn btn-sm btn-default">
                                <i class="fa-solid fa-list-check"></i> View Data Quality Report
                            </a>
                        }
                        else
                        {
                            <a href="@Url.Action("Index", "Reports")" class="btn btn-sm btn-default">
                                <i class="fa-solid fa-file-chart-column"></i> View Reports
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Help & Tutorial ── -->
    <div class="content-card">
        <div class="content-card-header" style="cursor:pointer;" onclick="toggleHelp()">
            <div class="d-flex align-items-center justify-content-between">
                <h4 class="mb-0"><i class="fa-solid fa-circle-question"></i> Help &amp; Feature Guide</h4>
                <i class="fa-solid fa-chevron-up" id="helpChevron" style="color:var(--color-primary);transition:transform 0.3s ease;"></i>
            </div>
        </div>
        <div id="helpSection">
            <div class="content-card-body">
                <div class="row g-3">
                    @foreach (var item in new[] {
                        new { Icon = "fa-users",          Title = "Customer Management",   Desc = "Add, edit and search customers. Each record tracks personal info, contact details, data quality score and risk score. Use the search bar on the Customers page to find records by name, email, phone or code." },
                        new { Icon = "fa-id-card",        Title = "ID Documents",          Desc = "Upload SA ID numbers, passports and professional registrations. All numbers are AES-256 encrypted. Click the lock icon on a document to reveal the number — this action is logged for audit purposes." },
                        new { Icon = "fa-credit-card",    Title = "Payment Methods",       Desc = "Store credit/debit cards and bank accounts securely. Card numbers are encrypted and only last 4 digits are shown. The dashboard alerts you when methods are expired or expiring soon." },
                        new { Icon = "fa-shield-halved",  Title = "Medical Clearance",     Desc = "Track TB tests, COVID vaccination status and background checks for customers attending on-site healthcare training. The dashboard alerts you when renewals are due." },
                        new { Icon = "fa-graduation-cap", Title = "Course Enrollments",    Desc = "Enrol customers in courses, track fees and payment status. The outstanding balance on this dashboard is the sum of all unpaid fees across all active enrollments." },
                        new { Icon = "fa-chart-bar",      Title = "Data Quality Scores",   Desc = "Every customer has an auto-calculated score (0–100%) based on profile completeness. Aim for 80%+ across all customers. A full Data Quality chart dashboard is coming soon." }
                    })
                    {
                        <div class="col-md-4">
                            <div class="help-card">
                                <div class="help-card-icon">
                                    <i class="fa-solid @item.Icon"></i>
                                </div>
                                <div>
                                    <div class="help-card-title">@item.Title</div>
                                    <p class="help-card-desc">@item.Desc</p>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}
else
{
    <!-- ── Getting Started (no customers) ── -->
    <div class="getting-started-hero mb-4">
        <div class="gs-hero-icon"><i class="fa-solid fa-rocket"></i></div>
        <h3>Welcome to TechSolutions CMS</h3>
        <p>You don't have any customers yet. Follow the steps below to get started.</p>
        <a href="@Url.Action("Create", "Customer")" class="btn btn-primary btn-lg mt-2">
            <i class="fa-solid fa-plus"></i> Add Your First Customer
        </a>
    </div>

    <div class="row g-3 mb-4">
        @foreach (var step in new[] {
            new { Num="1", Title="Add Your First Customer", Desc="Click Add Customer above. Fill in personal details, contact info and customer type to get started.",                          Icon="fa-user-plus"     },
            new { Num="2", Title="Upload ID Documents",     Desc="From the customer profile, upload SA ID, passport or professional registration. All numbers are encrypted automatically.",    Icon="fa-id-card"       },
            new { Num="3", Title="Add Payment Methods",     Desc="Store card or bank account details securely. Set a primary method and the system tracks expiry dates for you.",               Icon="fa-credit-card"   },
            new { Num="4", Title="Enrol in Courses",        Desc="Add course enrollments and track fees, payment status and completions. Certificates are recorded on the customer profile.",  Icon="fa-graduation-cap"}
        })
        {
            <div class="col-md-3 col-sm-6">
                <div class="getting-started-step">
                    <div class="gs-number">@step.Num</div>
                    <i class="fa-solid @step.Icon gs-icon"></i>
                    <h6 class="gs-title">@step.Title</h6>
                    <p class="gs-desc">@step.Desc</p>
                </div>
            </div>
        }
    </div>

    <div class="content-card">
        <div class="content-card-header">
            <h4 class="mb-0"><i class="fa-solid fa-circle-question"></i> Feature Guide</h4>
        </div>
        <div class="content-card-body">
            <div class="row g-3">
                @foreach (var item in new[] {
                    new { Icon="fa-shield-halved",  Title="Medical Clearance",   Desc="Track TB tests, COVID vaccination and background checks required for on-site training at healthcare facilities." },
                    new { Icon="fa-chart-bar",      Title="Data Quality Scores", Desc="Every customer gets an auto-calculated score. Aim for 80%+ by completing all profile fields — names, contact, address and DOB." },
                    new { Icon="fa-lock",           Title="AES-256 Encryption",  Desc="All sensitive data including ID numbers, card numbers and bank account numbers are encrypted before being stored in the database." }
                })
                {
                    <div class="col-md-4">
                        <div class="help-card">
                            <div class="help-card-icon"><i class="fa-solid @item.Icon"></i></div>
                            <div>
                                <div class="help-card-title">@item.Title</div>
                                <p class="help-card-desc">@item.Desc</p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

@section scripts {
    <style>
        .ops-alert-banner {
            display: flex;
            align-items: flex-start;
            gap: 14px;
            background: var(--color-warning-bg);
            border: 1.5px solid rgba(212,142,16,0.25);
            border-left: 4px solid var(--color-warning);
            border-radius: var(--radius-md);
            padding: 14px 18px;
            flex-wrap: wrap;
        }

        .ops-alert-icon {
            font-size: 1.1rem;
            color: var(--color-warning);
            flex-shrink: 0;
            padding-top: 2px;
        }

