@model List<TechSolutions.Models.Report>
@{
    ViewBag.Title = "Report Portal";
    var grouped = ViewBag.Grouped as Dictionary<string, List<TechSolutions.Models.Report>>;

    // Category icon/colour map
    var catMeta = new Dictionary<string, object[]>
{
        { "Customer",   new object[] { "fa-users",              "var(--color-primary)"   } },
        { "Compliance", new object[] { "fa-shield-halved",      "var(--color-secondary)" } },
        { "Financial",  new object[] { "fa-hand-holding-dollar","var(--color-success)"   } },
        { "Training",   new object[] { "fa-graduation-cap",     "var(--color-warning)"   } },
        { "Quality",    new object[] { "fa-chart-bar",          "var(--color-danger)"    } },
    };
}

<!-- Page Header -->
<div class="page-header">
    <div>
        <h2><i class="fa-solid fa-file-chart-column"></i> Report Portal</h2>
        <span class="text-muted" style="font-size:0.875rem;">
            @Model.Count report@(Model.Count == 1 ? "" : "s") available &mdash; Excel, PDF and print export
        </span>
    </div>
</div>

<!-- Search bar -->
<div class="page-search-bar mb-4">
    <div class="search-input-wrap">
        <i class="fa-solid fa-magnifying-glass search-icon"></i>
        <input type="text" id="reportSearch" class="form-control search-input"
               placeholder="Search reports…" oninput="filterReports(this.value)" />
    </div>
</div>

@if (grouped == null || !grouped.Any())
{
    <div class="empty-state" style="padding:60px 20px;">
        <i class="fa-solid fa-file-chart-column empty-state-icon"></i>
        <h5>No reports available</h5>
        <p>Run the database migration to seed the report definitions.</p>
    </div>
}
else
{
    foreach (var category in grouped)
    {
        string catIcon = catMeta.ContainsKey(category.Key) ? (string)catMeta[category.Key][0] : "fa-file";
        string catColor = catMeta.ContainsKey(category.Key) ? (string)catMeta[category.Key][1] : "var(--color-primary)";
        string catId = category.Key.Replace(" ", "_");
        int total = category.Value.Count;
        int initial = 4; // show 4 per category by default

        <div class="report-category mb-4" data-category="@category.Key">
            <div class="report-category-header" style="cursor:pointer;" onclick="toggleCategory('@catId')">
                <div class="report-category-icon" style="color:@catColor;">
                    <i class="fa-solid @catIcon"></i>
                </div>
                <h5 class="report-category-title">@category.Key Reports</h5>
                <span class="badge badge-default me-2">@total</span>
                <i class="fa-solid fa-chevron-down cat-chevron" id="chev-@catId"
                   style="color:var(--color-primary);transition:transform 0.3s ease;font-size:0.8rem;"></i>
            </div>

            <div class="cat-body" id="cat-@catId">
                <div class="row g-3" id="grid-@catId">
                    @for (int i = 0; i < category.Value.Count; i++)
                    {
                        var report = category.Value[i];
                        var formats = (report.ExportFormats ?? "").Split(',');
                        string hidden = i >= initial ? "report-card-hidden" : "";

                        <div class="col-md-6 report-card-wrap @hidden"
                             data-name="@report.ReportName.ToLower()"
                             data-index="@i">
                            <div class="report-card">
                                <div class="report-card-header">
                                    <div class="report-card-icon" style="color:@catColor;">
                                        <i class="fa-solid @report.IconClass"></i>
                                    </div>
                                    <div class="report-card-meta">
                                        <h6 class="report-card-title">@report.ReportName</h6>
                                        <span class="badge badge-@report.BadgeVariant">@report.Category</span>
                                    </div>
                                </div>
                                <p class="report-card-desc">@report.Description</p>
                                <div class="report-card-formats">
                                    @foreach (var fmt in formats)
                                    {
                                        string fmtIcon = fmt.Trim() == "Excel" ? "fa-file-excel" :
                                                         fmt.Trim() == "PDF" ? "fa-file-pdf" : "fa-print";
                                        <span class="format-chip">
                                            <i class="fa-solid @fmtIcon"></i> @fmt.Trim()
                                        </span>
                                    }
                                </div>
                                <div class="report-card-actions">
                                    <a href="@Url.Action("Run", new { id = report.ReportID })"
                                       class="btn btn-primary btn-sm">
                                        <i class="fa-solid fa-play"></i> Run Report
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @if (total > initial)
                {
                    <div class="show-more-wrap" id="more-@catId">
                        <button class="btn btn-default btn-sm show-more-btn"
                                onclick="showMore('@catId', @total, @initial)">
                            <i class="fa-solid fa-chevron-down"></i>
                            Show @(total - initial) more @category.Key.ToLower() report@(total - initial == 1 ? "" : "s")
                        </button>
                    </div>
                }
            </div>
        </div>
    }
}

@section scripts {
    <style>
        .search-input-wrap {
            position: relative;
            display: flex;
            align-items: center;
        }

        .search-icon {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--color-muted);
            font-size: 0.85rem;
            pointer-events: none;
            z-index: 2;
        }

        .search-input {
            padding-left: 36px !important;
        }

        .report-category-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 16px;
        }

        .report-category-icon {
            width: 36px;
            height: 36px;
            border-radius: var(--radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            flex-shrink: 0;
        }

        .report-category-title {
            font-size: 1rem;
            font-weight: 700;
            color: var(--color-text);
            margin: 0;
            flex: 1;
        }

        .report-card {
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-md);
            padding: 20px;
            height: 100%;
            display: flex;
            flex-direction: column;
            gap: 12px;
            transition: var(--transition);
        }

            .report-card:hover {
                border-color: var(--color-primary);
                box-shadow: var(--shadow-sm);
                transform: translateY(-2px);
            }

        .report-card-header {
            display: flex;
            align-items: flex-start;
            gap: 12px;
        }

        .report-card-icon {
            width: 40px;
            height: 40px;
            border-radius: var(--radius-sm);
            background: var(--color-primary-light);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            flex-shrink: 0;
        }

        .report-card-meta {
            flex: 1;
        }

        .report-card-title {
            font-size: 0.9rem;
            font-weight: 700;
            color: var(--color-text);
            margin: 0 0 4px;
        }

        .report-card-desc {
            font-size: 0.825rem;
            color: var(--color-muted);
            line-height: 1.5;
            margin: 0;
            flex: 1;
        }

        .report-card-formats {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
        }

        .format-chip {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-size: 0.72rem;
            font-weight: 600;
            color: var(--color-muted);
            background: var(--color-bg);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-pill);
            padding: 2px 8px;
        }

        .report-card-actions {
            display: flex;
            gap: 8px;
            margin-top: auto;
        }

        .empty-state {
            text-align: center;
            color: var(--color-muted);
        }

        .empty-state-icon {
            font-size: 3rem;
            opacity: 0.15;
            display: block;
            margin-bottom: 16px;
            color: var(--color-primary);
        }

        .empty-state h5 {
            color: var(--color-text);
            font-weight: 600;
            margin-bottom: 6px;
        }

        .empty-state p {
            font-size: 0.875rem;
        }

        .report-card-hidden {
            display: none;
        }

        .show-more-wrap {
            display: flex;
            justify-content: center;
            padding: 14px 0 4px;
        }

        .show-more-btn {
            font-size: 0.8rem;
            color: var(--color-primary);
            border-color: var(--color-primary);
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

            .show-more-btn:hover {
                background: var(--color-primary-light);
            }

        .cat-body {
            overflow: hidden;
            transition: all 0.3s ease;
        }
    </style>
    <script>
        function filterReports(query) {
            var q = query.toLowerCase().trim();
            document.querySelectorAll('.report-card-wrap').forEach(function (el) {
                var name = el.getAttribute('data-name') || '';
                el.style.display = (!q || name.includes(q)) ? '' : 'none';
            });
            // Hide empty category headers
            document.querySelectorAll('.report-category').forEach(function (cat) {
                var visible = Array.from(cat.querySelectorAll('.report-card-wrap'))
                    .some(function (el) { return el.style.display !== 'none'; });
                cat.style.display = visible ? '' : 'none';
            });
        }

        function toggleCategory(catId) {
            var body = document.getElementById('cat-' + catId);
            var chevron = document.getElementById('chev-' + catId);
            var isHidden = body.style.display === 'none';
            body.style.display = isHidden ? 'block' : 'none';
            chevron.style.transform = isHidden ? 'rotate(0deg)' : 'rotate(-90deg)';
        }

        function showMore(catId, total, initial) {
            var grid = document.getElementById('grid-' + catId);
            var btn = document.getElementById('more-' + catId);
            grid.querySelectorAll('.report-card-wrap').forEach(function (el) {
                el.style.display = '';
                el.classList.remove('report-card-hidden');
            });
            btn.style.display = 'none';
        }

        // Update filterReports to also reveal hidden cards when searching
        function filterReports(query) {
            var q = query.toLowerCase().trim();
            document.querySelectorAll('.report-card-wrap').forEach(function (el) {
                var name = el.getAttribute('data-name') || '';
                var matches = !q || name.includes(q);
                // When searching, always show matching cards even if hidden
                el.style.display = matches ? '' : 'none';
                if (matches && q) el.classList.remove('report-card-hidden');
            });
            document.querySelectorAll('.report-category').forEach(function (cat) {
                var visible = Array.from(cat.querySelectorAll('.report-card-wrap'))
                    .some(function (el) { return el.style.display !== 'none'; });
                cat.style.display = visible ? '' : 'none';
            });
            // Hide show-more buttons when actively searching
            document.querySelectorAll('.show-more-wrap').forEach(function (el) {
                el.style.display = q ? 'none' : '';
            });
        }
    </script>
}
