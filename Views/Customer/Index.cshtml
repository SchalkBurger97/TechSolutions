@model List<TechSolutions.Models.Customer>
@{
    ViewBag.Title = "Customer Management";
}

<div class="app-theme">
    <div class="container-fluid">
        <!-- Page Header -->
        <div class="row mb-3">
            <div class="col-md-6">
                <h2>Customer Management</h2>
                <p class="text-muted">Manage and view customer records</p>
            </div>
            @if (Model.Count > 0)
            {
                <div class="col-md-6 text-right">
                    <a href="@Url.Action("Create")" class="btn btn-primary" style="float:right">
                        <i class="fa fa-plus"></i> Add New Customer
                    </a>
                </div>
            }
        </div>

        <!-- Success/Error Messages -->
        @if (TempData["SuccessMessage"] != null || TempData["ErrorMessage"] != null)
        {
            <div id="toastContainer" style="position: fixed; top: 80px; right: 20px; z-index: 9999; min-width: 350px; max-width: 500px;">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible app-toast" role="alert" style="margin-bottom: 10px; box-shadow: 0 8px 16px rgba(0,0,0,0.2); border-left: 4px solid #3c763d; background-color: #dff0d8; border-radius: var(--border-radius);">
                        <button type="button" class="close app-toast-close" data-dismiss="alert" aria-label="Close" style="opacity: 1; color: #3c763d; font-size: 24px; font-weight: 300; line-height: 1; text-shadow: none;">
                            <span aria-hidden="true">&times;</span>
                        </button>
                        <div style="padding-right: 20px;">
                            <strong style="color: #3c763d;"><i class="fa fa-check-circle"></i> Success!</strong>
                            <div style="margin-top: 5px; color: #3c763d;">@TempData["SuccessMessage"]</div>
                        </div>
                    </div>
                }

                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible app-toast app-toast-error" role="alert" style="margin-bottom: 10px; box-shadow: 0 8px 16px rgba(0,0,0,0.2); border-left: 4px solid #a94442; background-color: #f2dede; border-radius: var(--border-radius);">
                        <button type="button" class="close app-toast-close" aria-label="Close" style="opacity: 1; color: #a94442; font-size: 24px; font-weight: 300; line-height: 1; text-shadow: none;">
                            <span aria-hidden="true">&times;</span>
                        </button>
                        <div style="padding-right: 20px;">
                            <strong style="color: #a94442;"><i class="fa fa-exclamation-triangle"></i> Error!</strong>
                            <div style="margin-top: 5px; color: #a94442;">@TempData["ErrorMessage"]</div>
                        </div>
                    </div>
                }
            </div>
        }

        <div class="panel panel-default">
            <div class="panel-heading" style="background: linear-gradient(135deg, var(--color-primary), var(--color-secondary)); color: #fff;">
                <h4 class="panel-title" style="margin: 0; color: #fff;">
                    <i class="fa fa-users"></i> Customer Directory
                </h4>
            </div>
            <div class="panel-body">
                <!-- Search Bar -->
                <form method="get" action="@Url.Action("Index")" class="form-inline" style="margin-bottom: 20px;">
                    <div class="form-group" style="width: 70%;">
                        <input type="text" name="search" class="form-control" style="width: 100%;"
                               placeholder="Search by name, email, phone, or customer code..."
                               value="@ViewBag.SearchTerm" />
                    </div>
                    <button type="submit" class="btn btn-primary">
                        <i class="fa fa-search"></i> Search
                    </button>
                    @if (!string.IsNullOrWhiteSpace(ViewBag.SearchTerm))
                    {
                        <a href="@Url.Action("Index")" class="btn btn-default">
                            <i class="fa fa-times"></i> Clear
                        </a>
                    }
                </form>

                <!-- Customer Table -->
                @if (Model.Count > 0)
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>Customer Code</th>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Phone</th>
                                    <th>Type</th>
                                    <th>Quality Score</th>
                                    <th>Status</th>
                                    <th style="width: 150px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var customer in Model)
                                {
                                    <tr>
                                        <td><strong>@customer.CustomerCode</strong></td>
                                        <td>@customer.FullName</td>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(customer.Email))
                                            {
                                                <a href="mailto:@customer.Email">@customer.Email</a>
                                            }
                                            else
                                            {
                                                <span class="text-muted">No email</span>
                                            }
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(customer.Phone))
                                            {
                                                @customer.Phone
                                            }
                                            else
                                            {
                                                <span class="text-muted">No phone</span>
                                            }
                                        </td>
                                        <td>
                                            <span class="label label-info" style="background-color: #d9edf7; color: #31708f; border: 1px solid #31708f; font-weight: 600;">
                                                @customer.CustomerType
                                            </span>
                                        </td>
                                        <td>
                                            @{
                                                var scoreClass = customer.DataQualityScore >= 80 ? "success" :
                                                                customer.DataQualityScore >= 60 ? "warning" : "danger";

                                                var scoreColor = customer.DataQualityScore >= 80 ? "#3c763d" :
                                                                customer.DataQualityScore >= 60 ? "#8a6d3b" : "#a94442";

                                                var scoreBg = customer.DataQualityScore >= 80 ? "#d4edda" :
                                                             customer.DataQualityScore >= 60 ? "#fcf8e3" : "#f2dede";
                                            }
                                            <span class="label label-@scoreClass" style="background-color: @scoreBg; color: @scoreColor; border: 1px solid @scoreColor; font-weight: 600;">
                                                @customer.DataQualityScore%
                                            </span>
                                        </td>
                                        <td>
                                            @if (customer.IsActive)
                                            {
                                                <span class="label label-success" style="background-color: #d4edda; color: #3c763d; border: 1px solid #3c763d; font-weight: 600;">
                                                    <i class="fa fa-check-circle"></i> Active
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="label label-danger" style="background-color: #f2dede; color: #a94442; border: 1px solid #a94442; font-weight: 600;">
                                                    <i class="fa fa-times-circle"></i> Inactive
                                                </span>
                                            }
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm">
                                                <a href="@Url.Action("Details", new { id = customer.CustomerID })"
                                                   class="btn btn-default" title="View Details">
                                                    <i class="fa fa-eye"></i>
                                                </a>
                                                <a href="@Url.Action("Edit", new { id = customer.CustomerID })"
                                                   class="btn btn-default" title="Edit">
                                                    <i class="fa fa-pencil"></i>
                                                </a>
                                                <button type="button" class="btn btn-danger" title="Delete"
                                                        onclick="confirmDelete(@customer.CustomerID, '@customer.FullName')">
                                                    <i class="fa fa-trash"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- Customer Count-->
                    <div class="row" style="margin-top: 15px; padding-top: 15px;">
                        <div class="col-md-6">
                            <p class="text-muted" style="margin: 0;">
                                <i class="fa fa-info-circle"></i> Showing <strong>@Model.Count</strong> of <strong>@ViewBag.TotalCustomers</strong> customers
                                @if (!string.IsNullOrWhiteSpace(ViewBag.SearchTerm))
                                {
                                    <span> (filtered by: "<strong>@ViewBag.SearchTerm</strong>")</span>
                                }
                            </p>
                        </div>
                        <div class="col-md-6">
                            <!-- Pagination -->
                            @if (ViewBag.TotalPages > 1)
                            {
                                <nav aria-label="Page navigation" class="text-right" style="margin: 0;">
                                    <ul class="pagination" style="margin: 0;">
                                        @if (ViewBag.CurrentPage > 1)
                                        {
                                            <li>
                                                <a href="@Url.Action("Index", new { search = ViewBag.SearchTerm, page = ViewBag.CurrentPage - 1 })">
                                                    <span aria-hidden="true">&laquo;</span>
                                                </a>
                                            </li>
                                        }

                                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                                        {
                                            <li class="@(i == ViewBag.CurrentPage ? "active" : "")">
                                                <a href="@Url.Action("Index", new { search = ViewBag.SearchTerm, page = i })">@i</a>
                                            </li>
                                        }

                                        @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                                        {
                                            <li>
                                                <a href="@Url.Action("Index", new { search = ViewBag.SearchTerm, page = ViewBag.CurrentPage + 1 })">
                                                    <span aria-hidden="true">&raquo;</span>
                                                </a>
                                            </li>
                                        }
                                    </ul>
                                </nav>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert alert-info" style="margin-top: 20px;">
                        <h4><i class="fa fa-info-circle"></i> No customers found</h4>
                        @if (!string.IsNullOrWhiteSpace(ViewBag.SearchTerm))
                        {
                            <p>No customers match your search term "<strong>@ViewBag.SearchTerm</strong>".</p>
                            <a href="@Url.Action("Index")" class="btn btn-default">
                                <i class="fa fa-times"></i> Clear Search
                            </a>
                        }
                        else
                        {
                            <p>Get started by adding your first customer.</p>
                            <a href="@Url.Action("Create")" class="btn btn-primary">
                                <i class="fa fa-plus"></i> Add New Customer
                            </a>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Delete Confirmation Modal (keep this at the bottom) -->
        <div class="modal fade app-confirm-modal" id="appConfirmModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h4 class="modal-title">Confirm Action</h4>
                    </div>
                    <div class="modal-body">
                        <p id="appConfirmMessage"></p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-primary" id="appConfirmOk">Confirm</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Hidden form for delete -->
    <form id="deleteForm" method="post" style="display:none;">
        @Html.AntiForgeryToken()
    </form>

    @section Scripts {
        <script>
        function confirmDelete(customerId, customerName) {
            $('#appConfirmMessage').text(
                'Are you sure you want to delete customer: ' + customerName + '?'
            );
            $('#appConfirmModal').modal('show');
            $('#appConfirmOk').off('click').on('click', function () {
                var form = document.getElementById('deleteForm');
                form.action = '@Url.Action("Delete", "Customer")' + '/' + customerId;
                form.submit();
            });
        }

        // Slide-in animation for toasts
        $(document).ready(function() {
            $('.app-toast').each(function(index) {
                var $toast = $(this);
                $toast.css({
                    'opacity': '0',
                    'transform': 'translateX(400px)'
                });

                setTimeout(function() {
                    $toast.animate({
                        'opacity': '1'
                    }, 400);
                    $toast.css({
                        'transform': 'translateX(0)',
                        'transition': 'transform 0.4s ease-out'
                    });
                }, index * 100);
            });
        });

        // Auto-hide ONLY success messages after 5 seconds (NOT errors)
        setTimeout(function () {
            $('.app-toast:not(.app-toast-error)').each(function(index) {
                var $toast = $(this);
                setTimeout(function() {
                    $toast.css({
                        'transform': 'translateX(400px)',
                        'transition': 'all 0.3s ease-in',
                        'opacity': '0'
                    });
                    setTimeout(function() {
                        $toast.remove();
                    }, 300);
                }, index * 100);
            });
        }, 5000);

        // Manual close with animation
        $('.app-toast-close').on('click', function() {
            var $toast = $(this).closest('.app-toast');
            $toast.css({
                'transform': 'translateX(400px)',
                'transition': 'all 0.3s ease-in',
                'opacity': '0'
            });
            setTimeout(function() {
                $toast.remove();
            }, 300);
        });
        </script>
    }

    <style>
        .mb-3 {
            margin-bottom: 1rem;
        }

        .table > tbody > tr > td {
            vertical-align: middle;
        }
    </style>
</div>