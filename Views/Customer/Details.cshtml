@section Scripts {
    <script>
        $(document).ready(function () {
            // Properly handle tab clicks and update active state
            $('.nav-tabs a').on('click', function (e) {
                e.preventDefault();

                // Remove active from all tabs
                $('.nav-tabs li').removeClass('active');

                // Add active to clicked tab
                $(this).parent('li').addClass('active');

                // Show the corresponding tab content
                var target = $(this).attr('href');
                $('.tab-pane').removeClass('active');
                $(target).addClass('active');
            });

            // Toast animations
            $('.app-toast').each(function (index) {
                var $toast = $(this);
                $toast.css({
                    'opacity': '0',
                    'transform': 'translateX(400px)'
                });

                setTimeout(function () {
                    $toast.animate({
                        'opacity': '1'
                    }, 400);
                    $toast.css({
                        'transform': 'translateX(0)',
                        'transition': 'transform 0.4s ease-out'
                    });
                }, index * 100);
            });
        });

        function confirmDelete(customerId, customerName) {
            if (confirm('Are you sure you want to delete customer: ' + customerName + '?\n\nThis action cannot be undone.')) {
                var form = document.getElementById('deleteForm');
                form.action = '@Url.Action("Delete", "Customer")' + '/' + customerId;
                form.submit();
            }
        }

        // Auto-hide ONLY success messages
        setTimeout(function () {
            $('.app-toast:not(.app-toast-error)').each(function (index) {
                var $toast = $(this);
                setTimeout(function () {
                    $toast.css({
                        'transform': 'translateX(400px)',
                        'transition': 'all 0.3s ease-in',
                        'opacity': '0'
                    });
                    setTimeout(function () {
                        $toast.remove();
                    }, 300);
                }, index * 100);
            });
        }, 5000);

        // Manual close
        $('.app-toast-close').on('click', function () {
            var $toast = $(this).closest('.app-toast');
            $toast.css({
                'transform': 'translateX(400px)',
                'transition': 'all 0.3s ease-in',
                'opacity': '0'
            });
            setTimeout(function () {
                $toast.remove();
            }, 300);
        });
    </script>
}