@model TechSolutions.Models.Customer

@{
    ViewBag.Title = "Customer Details";

    var initials = (Model.FirstName?.Substring(0, 1) ?? "") + (Model.LastName?.Substring(0, 1) ?? "");

    var qualityVariant = Model.DataQualityScore >= 80 ? "success" :
                         Model.DataQualityScore >= 60 ? "warning" : "danger";
    var qualityIcon = Model.DataQualityScore >= 80 ? "fa-circle-check" :
                         Model.DataQualityScore >= 60 ? "fa-circle-exclamation" : "fa-circle-xmark";

    var riskVariant = Model.RiskScore < 30 ? "success" :
                         Model.RiskScore < 60 ? "warning" : "danger";

    // Related data
    var documentCount = Model.IdentificationDocuments?.Count ?? 0;
    var clearance = Model.MedicalClearances?.FirstOrDefault();
    var hasClearance = clearance != null;
    var isCleared = hasClearance && clearance.ClearedForOnsiteTraining;
    var paymentMethods = Model.PaymentInformation?.Where(p => p.IsActive).ToList()
                              ?? new List<TechSolutions.Models.PaymentInformation>();
    var paymentCount = paymentMethods.Count;
    var primaryPayment = paymentMethods.FirstOrDefault(p => p.IsPrimary);
    var hasExpired = paymentMethods.Any(p => p.IsExpired);
    var hasExpiringSoon = paymentMethods.Any(p => p.IsExpiringSoon);
    var enrollments = Model.EnrollmentHistories?.ToList()
                              ?? new List<TechSolutions.Models.EnrollmentHistory>();
    var enrollmentCount = enrollments.Count;
    var activeEnrollments = enrollments.Count(e => e.EnrollmentStatus == "Active");
    var completedEnrollments = enrollments.Count(e => e.EnrollmentStatus == "Completed");
    var certificatesIssued = enrollments.Count(e => e.CertificateIssued);

    // Clearance status
    string clearanceStatus = "Not Set";
    string clearanceVariant = "default";
    string clearanceIcon = "fa-clock";
    if (hasClearance)
    {
        if (isCleared || clearance.ClearanceStatus == "Approved")
        {
            clearanceStatus = "Cleared"; clearanceVariant = "success"; clearanceIcon = "fa-circle-check";
        }
        else if (clearance.ClearanceStatus == "Rejected")
        {
            clearanceStatus = "Rejected"; clearanceVariant = "danger"; clearanceIcon = "fa-circle-xmark";
        }
        else
        {
            clearanceStatus = string.IsNullOrEmpty(clearance.ClearanceStatus) ? "Pending" : clearance.ClearanceStatus;
            clearanceVariant = "warning"; clearanceIcon = "fa-clock";
        }
    }

    // Quality field checks
    bool hasName = !string.IsNullOrWhiteSpace(Model.FirstName) && !string.IsNullOrWhiteSpace(Model.LastName);
    bool hasEmail = !string.IsNullOrWhiteSpace(Model.Email);
    bool hasPhone = !string.IsNullOrWhiteSpace(Model.Phone);
    bool hasDOB = Model.DateOfBirth.HasValue;
    bool hasAddress = !string.IsNullOrWhiteSpace(Model.Address);
    bool hasCity = !string.IsNullOrWhiteSpace(Model.City);
    bool hasProvince = !string.IsNullOrWhiteSpace(Model.Province);
    bool hasPostal = !string.IsNullOrWhiteSpace(Model.PostalCode);
    bool hasIdentity = !string.IsNullOrWhiteSpace(Model.IDNumber) || !string.IsNullOrWhiteSpace(Model.PassportNumber);

    int fieldsComplete = new[] { hasName, hasEmail, hasPhone, hasDOB, hasAddress, hasCity, hasProvince, hasPostal, hasIdentity }.Count(x => x);
}

<!-- Toast Notifications -->
@if (TempData["SuccessMessage"] != null || TempData["ErrorMessage"] != null)
{
    <div id="toastContainer" style="position:fixed;top:80px;right:20px;z-index:9999;min-width:340px;max-width:480px;">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="app-toast alert alert-success" role="alert">
                <strong><i class="fa-solid fa-circle-check"></i> Success</strong>
                <p class="mb-0 mt-1" style="font-size:0.825rem;">@TempData["SuccessMessage"]</p>
                <button class="app-toast-close" style="position:absolute;top:10px;right:12px;background:none;border:none;font-size:1.2rem;cursor:pointer;color:inherit;opacity:0.6;">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="app-toast app-toast-error alert alert-danger" role="alert">
                <strong><i class="fa-solid fa-triangle-exclamation"></i> Error</strong>
                <p class="mb-0 mt-1" style="font-size:0.825rem;">@TempData["ErrorMessage"]</p>
                <button class="app-toast-close" style="position:absolute;top:10px;right:12px;background:none;border:none;font-size:1.2rem;cursor:pointer;color:inherit;opacity:0.6;">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
        }
    </div>
}

<!-- Page Header -->
<div class="page-header">
    <div>
        <h2><i class="fa-solid fa-user"></i> Customer Details</h2>
        <span class="text-muted" style="font-size:0.875rem;">Viewing profile for @Model.FullName</span>
    </div>
    <a href="@Url.Action("Index")" class="btn btn-default">
        <i class="fa-solid fa-arrow-left"></i> Back to Customers
    </a>
</div>

<!-- ── Profile Hero Card ── -->
<div class="profile-hero mb-4">
    <div class="profile-hero-left">
        <!-- Avatar -->
        <div class="profile-avatar">
            <span>@initials</span>
        </div>
        <!-- Name & meta -->
        <div class="profile-meta">
            <h3 class="profile-name">@Model.FullName</h3>
            <div class="profile-tags">
                <span class="customer-code">@Model.CustomerCode</span>
                <span class="badge badge-info">@Model.CustomerType</span>
                @if (Model.IsActive)
                {
                    <span class="badge badge-success"><i class="fa-solid fa-circle-check"></i> Active</span>
                }
                else
                {
                    <span class="badge badge-danger"><i class="fa-solid fa-circle-xmark"></i> Inactive</span>
                }
            </div>
            <div class="profile-joined">
                <i class="fa-regular fa-calendar"></i>
                Member since @Model.CreatedDate.ToString("MMMM dd, yyyy")
            </div>
        </div>
    </div>

    <!-- Score metrics -->
    <div class="profile-scores">
        <div class="profile-score-item profile-score-@qualityVariant">
            <i class="fa-solid @qualityIcon"></i>
            <div>
                <div class="profile-score-value">@Model.DataQualityScore<span>%</span></div>
                <div class="profile-score-label">Data Quality</div>
            </div>
        </div>
        <div class="profile-score-item profile-score-@riskVariant">
            <i class="fa-solid fa-shield-halved"></i>
            <div>
                <div class="profile-score-value">@Model.RiskScore<span>/100</span></div>
                <div class="profile-score-label">Risk Score</div>
            </div>
        </div>
    </div>

    <!-- Action buttons -->
    <div class="profile-actions">
        <a href="@Url.Action("Edit", new { id = Model.CustomerID })" class="btn btn-primary">
            <i class="fa-solid fa-pen-to-square"></i> Edit
        </a>
        <button type="button" class="btn btn-danger" onclick="confirmDelete(@Model.CustomerID, '@Model.FullName')">
            <i class="fa-solid fa-trash"></i> Delete
        </button>
    </div>
</div>

<!-- ── Tabs ── -->
<ul class="nav nav-tabs" id="detailsTabs">
    <li class="nav-item">
        <a class="nav-link active" href="#overview" data-tab="overview">
            <i class="fa-solid fa-circle-info"></i> Overview
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link" href="#contact" data-tab="contact">
            <i class="fa-solid fa-envelope"></i> Contact
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link" href="#quality" data-tab="quality">
            <i class="fa-solid fa-chart-bar"></i> Data Quality
        </a>
    </li>
</ul>

<div class="tab-content mb-4">

    <!-- ── Tab: Overview ── -->
    <div class="tab-pane active" id="overview">
        <div class="row g-3">
            <!-- Personal Information -->
            <div class="col-md-6">
                <div class="detail-section">
                    <div class="detail-section-title">
                        <i class="fa-solid fa-user"></i> Personal Information
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">First Name</span>
                        <span class="detail-value">@Model.FirstName</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Last Name</span>
                        <span class="detail-value">@Model.LastName</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Date of Birth</span>
                        <span class="detail-value">
                            @if (Model.DateOfBirth.HasValue)
                            {
                                @Model.DateOfBirth.Value.ToString("MMMM dd, yyyy")
                                <span class="text-muted" style="font-size:0.8rem;">
                                    (@(DateTime.Now.Year - Model.DateOfBirth.Value.Year) years old)
                                </span>
                            }
                            else
                            {
                                <span class="text-muted fst-italic">Not provided</span>
                            }
                        </span>
                    </div>
                    <div class="detail-row" style="border-bottom:none;">
                        <span class="detail-label">Gender</span>
                        <span class="detail-value">
                            @if (string.IsNullOrWhiteSpace(Model.Gender))
                            {
                                <span class="text-muted fst-italic">Not specified</span>
                            }
                            else
                            {
                                @Model.Gender
                            }
                        </span>
                    </div>
                </div>
            </div>

            <!-- Account Information -->
            <div class="col-md-6">
                <div class="detail-section">
                    <div class="detail-section-title">
                        <i class="fa-solid fa-id-card"></i> Account Information
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Customer Code</span>
                        <span class="customer-code">@Model.CustomerCode</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Customer Type</span>
                        <span class="badge badge-info">@Model.CustomerType</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Status</span>
                        @if (Model.IsActive)
                        {
                            <span class="badge badge-success"><i class="fa-solid fa-circle-check"></i> Active</span>
                        }
                        else
                        {
                            <span class="badge badge-danger"><i class="fa-solid fa-circle-xmark"></i> Inactive</span>
                        }
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Created</span>
                        <span class="detail-value">@Model.CreatedDate.ToString("MMM dd, yyyy HH:mm")</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Identity</span>
                        <span class="detail-value">
                            @if (Model.IDType == "ID" && !string.IsNullOrWhiteSpace(Model.IDNumber))
                            {
                                <span class="badge badge-default"><i class="fa-solid fa-lock"></i> SA ID — Encrypted</span>
                            }
                            else if (Model.IDType == "Passport" && !string.IsNullOrWhiteSpace(Model.PassportNumber))
                            {
                                <span class="badge badge-default"><i class="fa-solid fa-lock"></i> Passport — Encrypted</span>
                            }
                            else
                            {
                                <span class="text-muted fst-italic">Not provided</span>
                            }
                        </span>
                    </div>
                    <div class="detail-row" style="border-bottom:none;">
                        <span class="detail-label">Last Modified</span>
                        <span class="detail-value">
                            @if (Model.ModifiedDate.HasValue)
                            {
                                @Model.ModifiedDate.Value.ToString("MMM dd, yyyy HH:mm")
                            }
                            else
                            {
                                <span class="text-muted fst-italic">Never</span>
                            }
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Tab: Contact ── -->
    <div class="tab-pane" id="contact">
        <div class="row g-3">
            <!-- Email & Phone -->
            <div class="col-md-6">
                <div class="detail-section">
                    <div class="detail-section-title">
                        <i class="fa-solid fa-address-book"></i> Contact Details
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Email</span>
                        <span class="detail-value">
                            @if (!string.IsNullOrWhiteSpace(Model.Email))
                            {
                                <a href="mailto:@Model.Email" class="table-link">
                                    <i class="fa-regular fa-envelope"></i> @Model.Email
                                </a>
                            }
                            else
                            {
                                <span class="text-muted fst-italic">Not provided</span>
                            }
                        </span>
                    </div>
                    <div class="detail-row" style="border-bottom:none;">
                        <span class="detail-label">Phone</span>
                        <span class="detail-value">
                            @if (!string.IsNullOrWhiteSpace(Model.Phone))
                            {
                                <span><i class="fa-solid fa-phone" style="opacity:0.5;"></i> @Model.Phone</span>
                            }
                            else
                            {
                                <span class="text-muted fst-italic">Not provided</span>
                            }
                        </span>
                    </div>
                </div>
            </div>

            <!-- Address -->
            <div class="col-md-6">
                <div class="detail-section">
                    <div class="detail-section-title">
                        <i class="fa-solid fa-location-dot"></i> Address
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.Address) || !string.IsNullOrWhiteSpace(Model.City))
                    {
                        <div class="detail-row">
                            <span class="detail-label">Street</span>
                            <span class="detail-value">@(string.IsNullOrWhiteSpace(Model.Address) ? "—" : Model.Address)</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">City</span>
                            <span class="detail-value">@(string.IsNullOrWhiteSpace(Model.City) ? "—" : Model.City)</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">Province</span>
                            <span class="detail-value">@(string.IsNullOrWhiteSpace(Model.Province) ? "—" : Model.Province)</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">Postal Code</span>
                            <span class="detail-value">@(string.IsNullOrWhiteSpace(Model.PostalCode) ? "—" : Model.PostalCode)</span>
                        </div>
                        <div class="detail-row" style="border-bottom:none;">
                            <span class="detail-label">Country</span>
                            <span class="detail-value"><strong>South Africa</strong></span>
                        </div>
                    }
                    else
                    {
                        <div class="empty-state" style="padding:28px 16px;">
                            <i class="fa-solid fa-location-dot empty-state-icon" style="font-size:2rem;"></i>
                            <p style="font-size:0.875rem;">No address on record</p>
                            <a href="@Url.Action("Edit", new { id = Model.CustomerID })" class="btn btn-sm btn-default">
                                <i class="fa-solid fa-pen-to-square"></i> Add Address
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- ── Tab: Data Quality ── -->
    <div class="tab-pane" id="quality">
        <!-- Score summary -->
        <div class="quality-summary mb-4">
            <div class="quality-summary-score quality-summary-@qualityVariant">
                <div class="qs-number">@Model.DataQualityScore<span>%</span></div>
                <div class="qs-label">Overall Score</div>
            </div>
            <div class="quality-summary-bar-wrap">
                <div class="quality-summary-bar">
                    <div class="quality-summary-fill quality-fill-@qualityVariant" style="width:@Model.DataQualityScore%"></div>
                </div>
                <div class="quality-summary-legend">
                    <span>@fieldsComplete of 9 fields complete</span>
                    @if (Model.DataQualityScore < 80)
                    {
                        <a href="@Url.Action("Edit", new { id = Model.CustomerID })" class="btn btn-sm btn-primary">
                            <i class="fa-solid fa-pen-to-square"></i> Improve Score
                        </a>
                    }
                </div>
            </div>
        </div>

        <!-- Field checklist -->
        <div class="row g-3">
            <div class="col-md-6">
                <div class="detail-section">
                    <div class="detail-section-title"><i class="fa-solid fa-user"></i> Personal Fields</div>
                    @foreach (var item in new[] {
                        new { Label = "Full Name",    Ok = hasName     },
                        new { Label = "Email Address",Ok = hasEmail    },
                        new { Label = "Phone Number", Ok = hasPhone    },
                        new { Label = "Date of Birth",Ok = hasDOB      },
                        new { Label = "Identity Number", Ok = hasIdentity }
                    })
                    {
                        <div class="quality-check-row @(item.Ok ? "qc-ok" : "qc-fail")">
                            <i class="fa-solid @(item.Ok ? "fa-circle-check" : "fa-circle-xmark")"></i>
                            <span>@item.Label</span>
                            <span class="ms-auto" style="font-size:0.75rem; font-weight:600;">
                                @(item.Ok ? "Complete" : "Missing")
                            </span>
                        </div>
                    }
                </div>
            </div>
            <div class="col-md-6">
                <div class="detail-section">
                    <div class="detail-section-title"><i class="fa-solid fa-location-dot"></i> Address Fields</div>
                    @foreach (var item in new[] {
                        new { Label = "Street Address",Ok = hasAddress  },
                        new { Label = "City",          Ok = hasCity     },
                        new { Label = "Province",      Ok = hasProvince },
                        new { Label = "Postal Code",   Ok = hasPostal   }
                    })
                    {
                        <div class="quality-check-row @(item.Ok ? "qc-ok" : "qc-fail")">
                            <i class="fa-solid @(item.Ok ? "fa-circle-check" : "fa-circle-xmark")"></i>
                            <span>@item.Label</span>
                            <span class="ms-auto" style="font-size:0.75rem; font-weight:600;">
                                @(item.Ok ? "Complete" : "Missing")
                            </span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- System info -->
        <div class="detail-section mt-3">
            <div class="detail-section-title"><i class="fa-solid fa-server"></i> System Information</div>
            <div class="row">
                <div class="col-md-6">
                    <div class="detail-row">
                        <span class="detail-label">Customer ID</span>
                        <span class="detail-value" style="font-family:var(--font-mono); font-size:0.85rem;">@Model.CustomerID</span>
                    </div>
                    <div class="detail-row" style="border-bottom:none;">
                        <span class="detail-label">Customer Code</span>
                        <span class="customer-code">@Model.CustomerCode</span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="detail-row">
                        <span class="detail-label">Risk Score</span>
                        <span class="badge badge-@riskVariant">@Model.RiskScore / 100</span>
                    </div>
                    <div class="detail-row" style="border-bottom:none;">
                        <span class="detail-label">Created</span>
                        <span class="detail-value">@Model.CreatedDate.ToString("yyyy-MM-dd HH:mm:ss")</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ── Related Information ── -->
<div class="content-card">
    <div class="content-card-header">
        <h4 class="mb-0"><i class="fa-solid fa-folder-open"></i> Related Information</h4>
    </div>
    <div class="content-card-body">
        <div class="row g-3">

            <!-- Documents -->
            <div class="col-md-3 col-sm-6">
                <a href="@Url.Action("Index", "Documents", new { customerId = Model.CustomerID })" class="related-card related-card-warning">
                    <div class="related-card-top">
                        <div>
                            <div class="related-card-label">Documents</div>
                            <div class="related-card-value">@documentCount</div>
                        </div>
                        <i class="fa-solid fa-id-card related-card-icon"></i>
                    </div>
                    <div class="related-card-footer">
                        <i class="fa-solid fa-arrow-right"></i> Manage Documents
                    </div>
                </a>
            </div>

            <!-- Payments -->
            <div class="col-md-3 col-sm-6">
                <a href="@Url.Action("Index", "Payment", new { customerId = Model.CustomerID })" class="related-card related-card-success">
                    <div class="related-card-top">
                        <div>
                            <div class="related-card-label">Payment Methods</div>
                            <div class="related-card-value">@paymentCount</div>
                        </div>
                        <i class="fa-solid fa-credit-card related-card-icon"></i>
                    </div>
                    @if (paymentCount > 0)
                    {
                        <div class="related-card-detail">
                            @if (primaryPayment != null)
                            {
                                <span>
                                    <i class="fa-solid fa-star"></i>
                                    @if (primaryPayment.PaymentMethodType == "Credit Card" || primaryPayment.PaymentMethodType == "Debit Card")
                                    {
                                        @(primaryPayment.CardType + " ••" + primaryPayment.CardLast4Digits)
                                    }
                                    else
                                    {
                                        @(primaryPayment.BankName + " ••" + primaryPayment.AccountLast4Digits)
                                    }
                                </span>
                            }
                            @if (hasExpired)
                            {
                                <span class="related-card-alert danger"><i class="fa-solid fa-triangle-exclamation"></i> Expired method</span>
                            }
                            else if (hasExpiringSoon)
                            {
                                <span class="related-card-alert warning"><i class="fa-solid fa-clock"></i> Expiring soon</span>
                            }
                        </div>
                    }
                    <div class="related-card-footer">
                        <i class="fa-solid fa-arrow-right"></i> Manage Payments
                    </div>
                </a>
            </div>

            <!-- Clearance -->
            <div class="col-md-3 col-sm-6">
                <a href="@Url.Action("Manage", "Clearance", new { customerId = Model.CustomerID })" class="related-card related-card-info">
                    <div class="related-card-top">
                        <div>
                            <div class="related-card-label">Medical Clearance</div>
                            <div class="mt-1">
                                <span class="badge badge-@clearanceVariant">
                                    <i class="fa-solid @clearanceIcon"></i> @clearanceStatus
                                </span>
                            </div>
                        </div>
                        <i class="fa-solid fa-shield-halved related-card-icon"></i>
                    </div>
                    @if (hasClearance)
                    {
                        <div class="related-card-detail">
                            <span class="@(clearance.HasTBTest ? "qc-ok-text" : "qc-fail-text")">
                                <i class="fa-solid @(clearance.HasTBTest ? "fa-check" : "fa-xmark")"></i> TB Test
                            </span>
                            <span class="@(clearance.HasCOVIDVaccination ? "qc-ok-text" : "qc-fail-text")">
                                <i class="fa-solid @(clearance.HasCOVIDVaccination ? "fa-check" : "fa-xmark")"></i> COVID Vaccination
                            </span>
                            <span class="@(clearance.HasBackgroundCheck ? "qc-ok-text" : "qc-fail-text")">
                                <i class="fa-solid @(clearance.HasBackgroundCheck ? "fa-check" : "fa-xmark")"></i> Background Check
                            </span>
                        </div>
                    }
                    <div class="related-card-footer">
                        <i class="fa-solid fa-arrow-right"></i> Manage Clearance
                    </div>
                </a>
            </div>

            <!-- Enrollments -->
            <div class="col-md-3 col-sm-6">
                <a href="@Url.Action("Index", "Enrollment", new { customerId = Model.CustomerID })" class="related-card related-card-primary">
                    <div class="related-card-top">
                        <div>
                            <div class="related-card-label">Enrollments</div>
                            <div class="related-card-value">@enrollmentCount</div>
                        </div>
                        <i class="fa-solid fa-graduation-cap related-card-icon"></i>
                    </div>
                    @if (enrollmentCount > 0)
                    {
                        <div class="related-card-detail">
                            <span><i class="fa-solid fa-book" style="color:var(--color-success);"></i> @activeEnrollments Active</span>
                            <span><i class="fa-solid fa-circle-check" style="color:var(--color-primary);"></i> @completedEnrollments Completed</span>
                            @if (certificatesIssued > 0)
                            {
                                <span><i class="fa-solid fa-certificate" style="color:var(--color-warning);"></i> @certificatesIssued Certificate@(certificatesIssued == 1 ? "" : "s")</span>
                            }
                        </div>
                    }
                    <div class="related-card-footer">
                        <i class="fa-solid fa-arrow-right"></i> View Training History
                    </div>
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:var(--radius-md);border:1px solid var(--color-border);overflow:hidden;">
            <div class="modal-header" style="background:var(--color-danger-bg);border-bottom:1px solid rgba(192,57,43,0.2);padding:16px 20px;">
                <h5 class="modal-title" style="color:var(--color-danger);font-weight:600;margin:0;">
                    <i class="fa-solid fa-triangle-exclamation"></i> Confirm Delete
                </h5>
            </div>
            <div class="modal-body" style="padding:20px;">
                <p id="deleteMessage" class="mb-0" style="font-size:0.9rem;"></p>
            </div>
            <div class="modal-footer" style="padding:12px 20px;border-top:1px solid var(--color-border);gap:8px;">
                <button type="button" class="btn btn-default" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">
                    <i class="fa-solid fa-trash"></i> Delete
                </button>
            </div>
        </div>
    </div>
</div>

<form id="deleteForm" method="post" style="display:none;">
    @Html.AntiForgeryToken()
</form>

@section Scripts {
    <style>
        /* ── Profile Hero ── */
        .profile-hero {
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-md);
            padding: 24px 28px;
            display: flex;
            align-items: center;
            gap: 24px;
            flex-wrap: wrap;
            box-shadow: var(--shadow-sm);
        }

        .profile-hero-left {
            display: flex;
            align-items: center;
            gap: 20px;
            flex: 1;
            min-width: 260px;
        }

        .profile-avatar {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.6rem;
            font-weight: 700;
            color: #fff;
            flex-shrink: 0;
            box-shadow: var(--shadow-sm);
            letter-spacing: -1px;
        }

        .profile-name {
            margin: 0 0 8px;
            font-size: 1.4rem;
            font-weight: 700;
            color: var(--color-text);
        }

        .profile-tags {
            display: flex;
            align-items: center;
            gap: 6px;
            flex-wrap: wrap;
            margin-bottom: 6px;
        }

        .profile-joined {
            font-size: 0.8rem;
            color: var(--color-muted);
            display: flex;
            align-items: center;
            gap: 6px;
        }

        /* Score chips */
        .profile-scores {
            display: flex;
            gap: 12px;
            flex-shrink: 0;
        }

        .profile-score-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 18px;
            border-radius: var(--radius-md);
            border: 1.5px solid transparent;
            font-size: 1.1rem;
        }

        .profile-score-success {
            background: var(--color-success-bg);
            border-color: rgba(46,158,107,0.2);
            color: var(--color-success);
        }

        .profile-score-warning {
            background: var(--color-warning-bg);
            border-color: rgba(212,142,16,0.2);
            color: var(--color-warning);
        }

        .profile-score-danger {
            background: var(--color-danger-bg);
            border-color: rgba(192,57,43,0.2);
            color: var(--color-danger);
        }

        .profile-score-value {
            font-size: 1.35rem;
            font-weight: 700;
            line-height: 1;
            letter-spacing: -0.5px;
        }

            .profile-score-value span {
                font-size: 0.8rem;
                font-weight: 500;
            }

        .profile-score-label {
            font-size: 0.72rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-top: 2px;
            opacity: 0.8;
        }

        .profile-actions {
            display: flex;
            flex-direction: column;
            gap: 8px;
            flex-shrink: 0;
        }

        /* ── Detail Sections ── */
        .detail-section {
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-md);
            overflow: hidden;
        }

        .detail-section-title {
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            color: var(--color-primary);
            padding: 12px 16px;
            background: var(--color-primary-light);
            border-bottom: 1px solid var(--color-border);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .detail-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 10px 16px;
            border-bottom: 1px solid var(--color-border);
            font-size: 0.855rem;
            gap: 12px;
        }

        .detail-label {
            font-weight: 600;
            color: var(--color-muted);
            font-size: 0.8rem;
            flex-shrink: 0;
            min-width: 110px;
        }

        .detail-value {
            color: var(--color-text);
        }

        /* ── Quality Tab ── */
        .quality-summary {
            display: flex;
            align-items: center;
            gap: 24px;
            background: var(--color-surface);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-md);
            padding: 20px 24px;
        }

        .quality-summary-score {
            text-align: center;
            flex-shrink: 0;
            padding: 12px 20px;
            border-radius: var(--radius-md);
            border: 1.5px solid transparent;
        }

        .quality-summary-success {
            background: var(--color-success-bg);
            border-color: rgba(46,158,107,0.2);
            color: var(--color-success);
        }

        .quality-summary-warning {
            background: var(--color-warning-bg);
            border-color: rgba(212,142,16,0.2);
            color: var(--color-warning);
        }

        .quality-summary-danger {
            background: var(--color-danger-bg);
            border-color: rgba(192,57,43,0.2);
            color: var(--color-danger);
        }

        .qs-number {
            font-size: 2.4rem;
            font-weight: 700;
            line-height: 1;
            letter-spacing: -2px;
        }

            .qs-number span {
                font-size: 1.1rem;
                font-weight: 500;
                letter-spacing: 0;
            }

        .qs-label {
            font-size: 0.72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-top: 4px;
            opacity: 0.8;
        }

        .quality-summary-bar-wrap {
            flex: 1;
        }

        .quality-summary-bar {
            height: 10px;
            background: var(--color-border);
            border-radius: var(--radius-pill);
            overflow: hidden;
            margin-bottom: 10px;
        }

        .quality-summary-fill {
            height: 100%;
            border-radius: var(--radius-pill);
            transition: width 0.8s var(--ease-out);
        }

        .quality-fill-success {
            background: linear-gradient(90deg, var(--color-success), #5dbe96);
        }

        .quality-fill-warning {
            background: linear-gradient(90deg, var(--color-warning), #e8ab42);
        }

        .quality-fill-danger {
            background: linear-gradient(90deg, var(--color-danger), #d9534f);
        }

        .quality-summary-legend {
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-size: 0.825rem;
            color: var(--color-muted);
        }

        /* Quality check rows */
        .quality-check-row {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 16px;
            border-bottom: 1px solid var(--color-border);
            font-size: 0.855rem;
        }

            .quality-check-row:last-child {
                border-bottom: none;
            }

        .qc-ok i {
            color: var(--color-success);
        }

        .qc-fail i {
            color: var(--color-danger);
        }

        .qc-ok-text {
            color: var(--color-success);
            font-size: 0.8rem;
        }

        .qc-fail-text {
            color: var(--color-danger);
            font-size: 0.8rem;
        }

        /* ── Related Cards ── */
        .related-card {
            display: flex;
            flex-direction: column;
            background: var(--color-surface);
            border: 1.5px solid var(--color-border);
            border-radius: var(--radius-md);
            overflow: hidden;
            text-decoration: none;
            color: var(--color-text);
            transition: all 0.25s var(--ease-out);
            height: 100%;
            border-left-width: 4px;
        }

            .related-card:hover {
                transform: translateY(-4px);
                box-shadow: var(--shadow-md);
                color: var(--color-text);
            }

        .related-card-primary {
            border-left-color: var(--color-primary);
        }

        .related-card-success {
            border-left-color: var(--color-success);
        }

        .related-card-warning {
            border-left-color: var(--color-warning);
        }

        .related-card-info {
            border-left-color: var(--color-secondary);
        }

        .related-card-top {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            padding: 18px 16px 10px;
        }

        .related-card-label {
            font-size: 0.72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            color: var(--color-muted);
            margin-bottom: 4px;
        }

        .related-card-value {
            font-size: 2rem;
            font-weight: 700;
            color: var(--color-text);
            line-height: 1;
            letter-spacing: -1px;
        }

        .related-card-icon {
            font-size: 2rem;
            opacity: 0.1;
        }

        .related-card-detail {
            padding: 0 16px 10px;
            display: flex;
            flex-direction: column;
            gap: 4px;
            font-size: 0.8rem;
            color: var(--color-muted);
        }

        .related-card-alert {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-weight: 600;
            font-size: 0.775rem;
        }

            .related-card-alert.danger {
                color: var(--color-danger);
            }

            .related-card-alert.warning {
                color: var(--color-warning);
            }

        .related-card-footer {
            margin-top: auto;
            padding: 10px 16px;
            border-top: 1px solid var(--color-border);
            font-size: 0.775rem;
            font-weight: 600;
            color: var(--color-muted);
            display: flex;
            align-items: center;
            gap: 6px;
            transition: var(--transition);
        }

        .related-card:hover .related-card-footer {
            color: var(--color-primary);
        }

        /* Toast */
        .app-toast {
            margin-bottom: 10px;
            position: relative;
        }

        /* table-link shared */
        .table-link {
            color: var(--color-primary);
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-size: 0.875rem;
        }

            .table-link:hover {
                color: var(--color-secondary);
            }
    </style>

    <script>
    // Tab switching
    document.querySelectorAll('#detailsTabs .nav-link').forEach(function (link) {
        link.addEventListener('click', function (e) {
            e.preventDefault();
            document.querySelectorAll('#detailsTabs .nav-link').forEach(l => l.classList.remove('active'));
            document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
            this.classList.add('active');
            var target = this.getAttribute('href').replace('#', '');
            document.getElementById(target).classList.add('active');
        });
    });

    // Delete modal
    function confirmDelete(customerId, customerName) {
        document.getElementById('deleteMessage').textContent =
            'Are you sure you want to permanently delete "' + customerName + '"? This action cannot be undone.';
        new bootstrap.Modal(document.getElementById('deleteModal')).show();
        document.getElementById('confirmDeleteBtn').onclick = function () {
            var form = document.getElementById('deleteForm');
            form.action = '@Url.Action("Delete", "Customer")' + '/' + customerId;
            form.submit();
        };
    }

    // Toast auto-dismiss
    setTimeout(function () {
        document.querySelectorAll('.app-toast:not(.app-toast-error)').forEach(function (el) {
            el.style.transition = 'all 0.35s ease-in';
            el.style.opacity = '0';
            el.style.transform = 'translateX(120%)';
            setTimeout(function () { el.remove(); }, 350);
        });
    }, 5000);

    document.querySelectorAll('.app-toast-close').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var toast = this.closest('.app-toast');
            toast.style.transition = 'all 0.3s ease-in';
            toast.style.opacity = '0';
            toast.style.transform = 'translateX(120%)';
            setTimeout(function () { toast.remove(); }, 300);
        });
    });
    </script>
}
