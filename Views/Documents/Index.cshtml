@model List<TechSolutions.Models.IdentificationDocument>

@{
    ViewBag.Title = "ID Documents";
    var customer = ViewBag.Customer as TechSolutions.Models.Customer;
    var verifiedCount = Model.Count(d => d.IsVerified);
    var expiredCount = Model.Count(d => d.ExpiryDate.HasValue && d.ExpiryDate.Value < DateTime.Now);
    var expiringSoon = Model.Count(d => d.ExpiryDate.HasValue
                                     && d.ExpiryDate.Value >= DateTime.Now
                                     && d.ExpiryDate.Value < DateTime.Now.AddMonths(3));
}

<!-- Toast Notifications -->
@if (TempData["SuccessMessage"] != null || TempData["ErrorMessage"] != null)
{
    <div id="toastContainer" style="position:fixed;top:80px;right:20px;z-index:9999;min-width:340px;max-width:480px;">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="app-toast alert alert-success" role="alert">
                <strong><i class="fa-solid fa-circle-check"></i> Success</strong>
                <p class="mb-0 mt-1" style="font-size:0.825rem;">@TempData["SuccessMessage"]</p>
                <button class="app-toast-close" style="position:absolute;top:10px;right:12px;background:none;border:none;font-size:1.2rem;cursor:pointer;color:inherit;opacity:0.6;">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="app-toast app-toast-error alert alert-danger" role="alert">
                <strong><i class="fa-solid fa-triangle-exclamation"></i> Error</strong>
                <p class="mb-0 mt-1" style="font-size:0.825rem;">@TempData["ErrorMessage"]</p>
                <button class="app-toast-close" style="position:absolute;top:10px;right:12px;background:none;border:none;font-size:1.2rem;cursor:pointer;color:inherit;opacity:0.6;">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
        }
    </div>
}

<!-- Page Header -->
<div class="page-header">
    <div>
        <h2><i class="fa-solid fa-id-card"></i> ID Documents</h2>
        <span class="text-muted" style="font-size:0.875rem;">
            @customer.FullName &mdash;
            <span class="customer-code">@customer.CustomerCode</span>
        </span>
    </div>
    <div style="display:flex;gap:8px;align-items:center;">
        <a href="@Url.Action("Details", "Customer", new { id = customer.CustomerID })" class="btn btn-default">
            <i class="fa-solid fa-arrow-left"></i> Back to Profile
        </a>
        <a href="@Url.Action("Create", new { customerId = customer.CustomerID })" class="btn btn-primary">
            <i class="fa-solid fa-plus"></i> Add Document
        </a>
    </div>
</div>

<!-- Security Notice -->
<div class="alert alert-info mb-4" style="border-left-width:4px;">
    <i class="fa-solid fa-circle-info"></i>
    Document files are encrypted at rest. Use the download button to access uploaded scans.
</div>

<!-- Summary Stats -->
@if (Model.Count > 0)
{
    <div class="row g-3 mb-4">
        <div class="col-sm-3">
            <div class="stat-card stat-card-primary">
                <div class="stat-card-label">Total Documents</div>
                <div class="stat-card-value stat-card-value-md">@Model.Count</div>
                <i class="fa-solid fa-id-card card-icon"></i>
            </div>
        </div>
        <div class="col-sm-3">
            <div class="stat-card stat-card-success">
                <div class="stat-card-label">Verified</div>
                <div class="stat-card-value stat-card-value-md">@verifiedCount</div>
                <i class="fa-solid fa-circle-check card-icon"></i>
            </div>
        </div>
        <div class="col-sm-3">
            <div class="stat-card stat-card-warning">
                <div class="stat-card-label">Expiring Soon</div>
                <div class="stat-card-value stat-card-value-md">@expiringSoon</div>
                <i class="fa-solid fa-clock card-icon"></i>
            </div>
        </div>
        <div class="col-sm-3">
            <div class="stat-card stat-card-danger">
                <div class="stat-card-label">Expired</div>
                <div class="stat-card-value stat-card-value-md">@expiredCount</div>
                <i class="fa-solid fa-circle-xmark card-icon"></i>
            </div>
        </div>
    </div>
}

<!-- Documents Table -->
<div class="content-card">
    <div class="content-card-header d-flex align-items-center justify-content-between">
        <h4 class="mb-0">
            <i class="fa-solid fa-folder-open"></i> Identification Documents
        </h4>
        <span class="text-muted" style="font-size:0.8rem;font-weight:500;">
            @Model.Count document@(Model.Count == 1 ? "" : "s")
        </span>
    </div>
    <div class="content-card-body p-0">
        @if (Model.Count > 0)
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Document Type</th>
                            <th>Document Number</th>
                            <th>Issuing Country</th>
                            <th>Issue Date</th>
                            <th>Expiry Date</th>
                            <th>Status</th>
                            <th style="width:130px;text-align:center;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var doc in Model)
                        {
                            bool isExpired = doc.ExpiryDate.HasValue && doc.ExpiryDate.Value < DateTime.Now;
                            bool isExpiringSoon = doc.ExpiryDate.HasValue
                                               && doc.ExpiryDate.Value >= DateTime.Now
                                               && doc.ExpiryDate.Value < DateTime.Now.AddMonths(3);

                            string expiryVariant = isExpired ? "danger" : isExpiringSoon ? "warning" : "";

                            <tr>
                                <td>
                                    <strong>@doc.DocumentType</strong>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(doc.DocumentNumber))
                                    {
                                        <span class="doc-ref-pill">
                                            <i class="fa-solid fa-hashtag"></i>
                                            @doc.DocumentNumber
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic" style="font-size:0.8rem;">Not assigned</span>
                                    }
                                </td>
                                <td>@doc.IssuingCountry</td>
                                <td style="font-size:0.85rem;">
                                    @(doc.IssueDate.HasValue ? doc.IssueDate.Value.ToString("MMM dd, yyyy") : "—")
                                </td>
                                <td>
                                    @if (doc.ExpiryDate.HasValue)
                                    {
                                        <span class="@(isExpired ? "text-danger" : isExpiringSoon ? "text-warning" : "")" style="font-size:0.85rem;">
                                            @doc.ExpiryDate.Value.ToString("MMM dd, yyyy")
                                        </span>
                                        if (isExpired)
                                        {
                                            <span class="badge badge-danger ms-1">Expired</span>
                                        }
                                        else if (isExpiringSoon)
                                        {
                                            <span class="badge badge-warning ms-1">Expiring Soon</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="badge badge-default">No Expiry</span>
                                    }
                                </td>
                                <td>
                                    @if (doc.IsVerified)
                                    {
                                        <span class="badge badge-success">
                                            <i class="fa-solid fa-circle-check"></i> Verified
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-warning">
                                            <i class="fa-solid fa-clock"></i> Pending
                                        </span>
                                    }
                                </td>
                                <td>
                                    <div class="table-actions">
                                        @if (!string.IsNullOrEmpty(doc.DocumentFilePath))
                                        {
                                            <a href="@Url.Action("Download", "Documents", new { id = doc.DocumentID })"
                                               class="table-action-btn" title="Download" target="_blank">
                                                <i class="fa-solid fa-download"></i>
                                            </a>
                                        }
                                        <a href="@Url.Action("Edit", "Documents", new { id = doc.DocumentID })"
                                           class="table-action-btn" title="Edit">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </a>
                                        <button type="button" class="table-action-btn table-action-danger" title="Delete"
                                                onclick="confirmDelete(@doc.DocumentID, '@doc.DocumentType.Replace("'", "\\'")', @customer.CustomerID)">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <i class="fa-solid fa-id-card empty-state-icon"></i>
                <h5>No documents on record</h5>
                <p>No identification documents have been added for this customer yet.</p>
                <a href="@Url.Action("Create", new { customerId = customer.CustomerID })" class="btn btn-primary">
                    <i class="fa-solid fa-plus"></i> Add First Document
                </a>
            </div>
        }
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:var(--radius-md);border:1px solid var(--color-border);overflow:hidden;">
            <div class="modal-header" style="background:var(--color-danger-bg);border-bottom:1px solid rgba(192,57,43,0.2);padding:16px 20px;">
                <h5 class="modal-title" style="color:var(--color-danger);font-weight:600;margin:0;">
                    <i class="fa-solid fa-triangle-exclamation"></i> Confirm Delete
                </h5>
            </div>
            <div class="modal-body" style="padding:20px;">
                <p id="deleteMessage" class="mb-0" style="font-size:0.9rem;"></p>
            </div>
            <div class="modal-footer" style="padding:12px 20px;border-top:1px solid var(--color-border);gap:8px;">
                <button type="button" class="btn btn-default" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">
                    <i class="fa-solid fa-trash"></i> Delete
                </button>
            </div>
        </div>
    </div>
</div>

<form id="deleteForm" method="post" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="customerId" id="deleteCustomerId" />
</form>

@section Scripts {
    <style>
        /* ── Document number toggle ── */
        .doc-ref-pill {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-family: var(--font-mono);
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--color-primary);
            background: var(--color-primary-light);
            border: 1px solid rgba(4, 119, 191, 0.2);
            padding: 2px 8px;
            border-radius: var(--radius-pill);
        }

        .doc-lock-icon {
            font-size: 0.75rem;
            flex-shrink: 0;
        }

        /* Shared table utilities */
        .table-actions {
            display: flex;
            gap: 4px;
            justify-content: center;
        }

        .table-action-btn {
            width: 30px;
            height: 30px;
            border-radius: var(--radius-sm);
            border: 1.5px solid var(--color-border);
            background: var(--color-surface);
            color: var(--color-muted);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 0.8rem;
            cursor: pointer;
            transition: var(--transition);
            text-decoration: none;
        }

            .table-action-btn:hover {
                background: var(--color-primary-light);
                border-color: var(--color-primary);
                color: var(--color-primary);
                transform: translateY(-1px);
            }

        .table-action-danger:hover {
            background: var(--color-danger-bg);
            border-color: var(--color-danger);
            color: var(--color-danger);
        }

        /* Customer code pill */
        .customer-code {
            font-family: var(--font-mono);
            font-size: 0.8rem;
            background: var(--color-primary-light);
            color: var(--color-primary);
            padding: 2px 8px;
            border-radius: var(--radius-pill);
            font-weight: 500;
        }

        /* Empty state */
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: var(--color-muted);
        }

        .empty-state-icon {
            font-size: 3.5rem;
            opacity: 0.18;
            display: block;
            margin-bottom: 20px;
            color: var(--color-primary);
        }

        .empty-state h5 {
            color: var(--color-text);
            font-weight: 600;
            margin-bottom: 8px;
        }

        .empty-state p {
            font-size: 0.875rem;
            margin-bottom: 20px;
        }

        /* Toast */
        .app-toast {
            margin-bottom: 10px;
            position: relative;
        }
    </style>

    <script>
    
    // ── Delete modal ──
    function confirmDelete(documentId, documentType, customerId) {
        document.getElementById('deleteMessage').textContent =
            'Are you sure you want to delete this ' + documentType + '? This action cannot be undone.';
        document.getElementById('deleteCustomerId').value = customerId;

        var modal = new bootstrap.Modal(document.getElementById('deleteModal'));
        modal.show();

        document.getElementById('confirmDeleteBtn').onclick = function () {
            var form = document.getElementById('deleteForm');
            form.action = '@Url.Action("Delete", "Documents")' + '/' + documentId;
            form.submit();
        };
    }

    // ── Toast auto-dismiss ──
    setTimeout(function () {
        document.querySelectorAll('.app-toast:not(.app-toast-error)').forEach(function (el) {
            el.style.transition = 'all 0.35s ease-in';
            el.style.opacity = '0';
            el.style.transform = 'translateX(120%)';
            setTimeout(function () { el.remove(); }, 350);
        });
    }, 5000);

    document.querySelectorAll('.app-toast-close').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var toast = this.closest('.app-toast');
            toast.style.transition = 'all 0.3s ease-in';
            toast.style.opacity = '0';
            toast.style.transform = 'translateX(120%)';
            setTimeout(function () { toast.remove(); }, 300);
        });
    });
    </script>
}
