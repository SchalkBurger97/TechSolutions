@model List<TechSolutions.Models.IdentificationDocument>

@{
    ViewBag.Title = "ID Documents";
    var customer = ViewBag.Customer as TechSolutions.Models.Customer;
}

<div class="app-theme">

    <style>
        .doc-number-toggle {
            transition: all 0.3s ease;
            padding: 3px 8px;
            border-radius: 4px;
        }

            .doc-number-toggle:hover {
                background: #f5f5f5;
            }

            .doc-number-toggle .toggle-icon {
                margin-right: 5px;
                transition: transform 0.3s ease;
            }

            .doc-number-toggle:hover .toggle-icon {
                transform: scale(1.2);
            }
    </style>

    <!-- Toast Alerts -->
    @if (TempData["SuccessMessage"] != null || TempData["ErrorMessage"] != null)
    {
        <div id="toastContainer" style="position: fixed; top: 80px; right: 20px; z-index: 9999; min-width: 350px; max-width: 500px;">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible app-toast" role="alert" style="margin-bottom: 10px; box-shadow: 0 8px 16px rgba(0,0,0,0.2); border-left: 4px solid #3c763d; background-color: #dff0d8; border-radius: var(--border-radius);">
                    <button type="button" class="close app-toast-close" aria-label="Close" style="opacity: 1; color: #3c763d; font-size: 24px; font-weight: 300; line-height: 1; text-shadow: none;">
                        <span aria-hidden="true">&times;</span>
                    </button>
                    <div style="padding-right: 20px;">
                        <strong style="color: #3c763d;"><i class="fa fa-check-circle"></i> Success!</strong>
                        <div style="margin-top: 5px; color: #3c763d;">@TempData["SuccessMessage"]</div>
                    </div>
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible app-toast app-toast-error" role="alert" style="margin-bottom: 10px; box-shadow: 0 8px 16px rgba(0,0,0,0.2); border-left: 4px solid #a94442; background-color: #f2dede; border-radius: var(--border-radius);">
                    <button type="button" class="close app-toast-close" aria-label="Close" style="opacity: 1; color: #a94442; font-size: 24px; font-weight: 300; line-height: 1; text-shadow: none;">
                        <span aria-hidden="true">&times;</span>
                    </button>
                    <div style="padding-right: 20px;">
                        <strong style="color: #a94442;"><i class="fa fa-exclamation-triangle"></i> Error!</strong>
                        <div style="margin-top: 5px; color: #a94442;">@TempData["ErrorMessage"]</div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="container-fluid">
        <!-- Back Button -->
        <div class="row" style="margin-bottom: 15px;">
            <div class="col-md-12">
                <a href="@Url.Action("Details", "Customer", new { id = customer.CustomerID })" class="btn btn-default">
                    <i class="fa fa-arrow-left"></i> Back to Customer Details
                </a>
            </div>
        </div>

        <!-- Page Header -->
        <div class="row" style="margin-bottom: 20px;">
            <div class="col-md-12">
                <div class="panel panel-primary">
                    <div class="panel-heading" style="background: linear-gradient(135deg, var(--color-primary), var(--color-secondary)); border: none;">
                        <h3 class="panel-title" style="color: #fff; font-size: 18px; margin: 0;">
                            <i class="fa fa-id-card"></i> ID Documents - @customer.FullName
                        </h3>
                    </div>
                    <div class="panel-body" style="padding: 15px; background: var(--color-bg);">
                        <p style="margin: 0; color: #666;">
                            <strong>Customer Code:</strong> <span style="color: var(--color-primary); font-weight: 600;">@customer.CustomerCode</span>
                            <span style="margin: 0 10px;">|</span>
                            <i class="fa fa-lock" style="color: #d9534f;"></i> <strong style="color: #d9534f;">Sensitive Data - Handle with Care</strong>
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Add New Document Button -->
        <div class="row" style="margin-bottom: 20px;">
            <div class="col-md-12">
                <a href="@Url.Action("Create", new { customerId = customer.CustomerID })" class="btn btn-primary">
                    <i class="fa fa-plus"></i> Add New Document
                </a>
            </div>
        </div>

        <!-- Documents List -->
        <div class="row">
            <div class="col-md-12">
                <div class="panel panel-default">
                    <div class="panel-heading" style="background: var(--color-bg); border: none;">
                        <h4 class="panel-title" style="color: var(--color-primary); margin: 0;">
                            <i class="fa fa-folder-open"></i> Identification Documents (@Model.Count)
                        </h4>
                    </div>
                    <div class="panel" style="padding: 0;">
                        @if (Model.Count > 0)
                        {
                            <div class="table-responsive">
                                <table class="table table-striped table-hover">
                                    <thead>
                                        <tr>
                                            <th>Document Type</th>
                                            <th>Document Number</th>
                                            <th>Issuing Country</th>
                                            <th>Issue Date</th>
                                            <th>Expiry Date</th>
                                            <th>Status</th>
                                            <th style="width: 180px;">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var doc in Model)
                                        {
                                            <tr>
                                                <td><strong>@doc.DocumentType</strong></td>
                                                <td>
                                                    @{
                                                        var displayNumber = "";
                                                        var fullNumber = "";
                                                        var fieldType = "";

                                                        // Decrypt and get the appropriate number
                                                        if (!string.IsNullOrEmpty(doc.IDNumber))
                                                        {
                                                            try
                                                            {
                                                                fullNumber = TechSolutions.Helpers.EncryptionHelper.DecryptString(doc.IDNumber);
                                                                displayNumber = TechSolutions.Helpers.EncryptionHelper.MaskSensitiveData(fullNumber, 4);
                                                                fieldType = "ID Number";
                                                            }
                                                            catch
                                                            {
                                                                displayNumber = "****";
                                                                fullNumber = "";
                                                            }
                                                        }
                                                        else if (!string.IsNullOrEmpty(doc.PassportNumber))
                                                        {
                                                            try
                                                            {
                                                                fullNumber = TechSolutions.Helpers.EncryptionHelper.DecryptString(doc.PassportNumber);
                                                                displayNumber = TechSolutions.Helpers.EncryptionHelper.MaskSensitiveData(fullNumber, 4);
                                                                fieldType = "Passport";
                                                            }
                                                            catch
                                                            {
                                                                displayNumber = "****";
                                                                fullNumber = "";
                                                            }
                                                        }
                                                        else if (!string.IsNullOrEmpty(doc.ProfessionalRegNumber))
                                                        {
                                                            try
                                                            {
                                                                fullNumber = TechSolutions.Helpers.EncryptionHelper.DecryptString(doc.ProfessionalRegNumber);
                                                                displayNumber = TechSolutions.Helpers.EncryptionHelper.MaskSensitiveData(fullNumber, 4);
                                                                fieldType = "Professional Reg";
                                                            }
                                                            catch
                                                            {
                                                                displayNumber = "****";
                                                                fullNumber = "";
                                                            }
                                                        }

                                                        if (!string.IsNullOrEmpty(displayNumber))
                                                        {
                                                            <span class="doc-number-toggle" data-doc-id="@doc.DocumentID" data-full-number="@fullNumber" data-field-type="@fieldType" style="cursor: pointer; font-family: monospace; color: #d9534f;">
                                                                <i class="fa fa-lock toggle-icon"></i>
                                                                <span class="doc-number-display">@displayNumber</span>
                                                            </span>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-muted">Not provided</span>
                                                        }
                                                    }
                                                </td>
                                                <td>@doc.IssuingCountry</td>
                                                <td>
                                                    @if (doc.IssueDate.HasValue)
                                                    {
                                                        @doc.IssueDate.Value.ToString("MMM dd, yyyy")
                                                    }
                                                </td>
                                                <td>
                                                    @if (doc.ExpiryDate.HasValue)
                                                    {
                                                        var isExpired = doc.ExpiryDate.Value < DateTime.Now;
                                                        var isExpiringSoon = doc.ExpiryDate.Value < DateTime.Now.AddMonths(3) && !isExpired;

                                                        <span style="color: @(isExpired ? "#d9534f" : isExpiringSoon ? "#f0ad4e" : "#333");">
                                                            @doc.ExpiryDate.Value.ToString("MMM dd, yyyy")
                                                            @if (isExpired)
                                                            {
                                                                <span class="label label-danger" style="margin-left: 5px;">Expired</span>
                                                            }
                                                            else if (isExpiringSoon)
                                                            {
                                                                <span class="label label-warning" style="margin-left: 5px;">Expiring Soon</span>
                                                            }
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="label" style="margin-left: 5px;">No Expiry date</span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (doc.IsVerified)
                                                    {
                                                        <span class="label label-success" style="background-color: #d4edda; color: #3c763d; border: 1px solid #3c763d; font-weight: 600;">
                                                            <i class="fa fa-check-circle"></i> Verified
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="label label-warning" style="background-color: #fcf8e3; color: #8a6d3b; border: 1px solid #8a6d3b; font-weight: 600;">
                                                            <i class="fa fa-clock-o"></i> Pending
                                                        </span>
                                                    }
                                                </td>
                                                <td>
                                                    <div class="btn-group btn-group-sm">
                                                        @if (!string.IsNullOrEmpty(doc.DocumentFilePath))
                                                        {
                                                            <a href="@Url.Action("Download", "Documents", new { id = doc.DocumentID })" class="btn btn-default" title="Download Document" target="_blank">
                                                                <i class="fa fa-download"></i>
                                                            </a>
                                                        }
                                                        <a href="@Url.Action("Edit", "Documents", new { id = doc.DocumentID })" class="btn btn-default" title="Edit">
                                                            <i class="fa fa-pencil"></i>
                                                        </a>
                                                        <button type="button" class="btn btn-danger" title="Delete" onclick="confirmDelete(@doc.DocumentID, '@doc.DocumentType.Replace("'", "\\'"), @customer.CustomerID)">
                                                            <i class="fa fa-trash"></i>
                                                        </button>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info" style="margin: 20px;">
                                <h4><i class="fa fa-info-circle"></i> No Documents Found</h4>
                                <p>No identification documents have been added for this customer yet.</p>
                                <a href="@Url.Action("Create", new { customerId = customer.CustomerID })" class="btn btn-primary">
                                    <i class="fa fa-plus"></i> Add First Document
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <form id="deleteForm" method="post" style="display:none;">
        @Html.AntiForgeryToken()
        <input type="hidden" name="customerId" id="deleteCustomerId" />
    </form>

    <div class="modal fade" id="deleteModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                    <h4 class="modal-title">Confirm Delete</h4>
                </div>
                <div class="modal-body">
                    <p id="deleteMessage"></p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger" id="confirmDelete">Delete</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Toggle document number visibility
        $(document).on('click', '.doc-number-toggle', function () {
            var $this = $(this);
            var $icon = $this.find('.toggle-icon');
            var $display = $this.find('.doc-number-display');
            var fullNumber = String($this.data('full-number')); // Convert to string
            var fieldType = $this.data('field-type');
            var currentText = $display.text();

            // Check if currently showing full number
            if ($icon.hasClass('fa-unlock')) {
                // Hide - show masked version
                var masked = '';
                if (fullNumber && fullNumber.length > 4) {
                    masked = '*'.repeat(fullNumber.length - 4) + fullNumber.slice(-4);
                } else {
                    masked = '****';
                }
                $display.text(masked);
                $icon.removeClass('fa-unlock').addClass('fa-lock');
                $this.css('color', '#d9534f');
            } else {
                // Show full number
                $display.text(fullNumber);
                $icon.removeClass('fa-lock').addClass('fa-unlock');
                $this.css('color', '#5cb85c');

                // Auto-hide after 10 seconds
                setTimeout(function () {
                    if ($icon.hasClass('fa-unlock')) {
                        var masked = '';
                        if (fullNumber && fullNumber.length > 4) {
                            masked = '*'.repeat(fullNumber.length - 4) + fullNumber.slice(-4);
                        } else {
                            masked = '****';
                        }
                        $display.text(masked);
                        $icon.removeClass('fa-unlock').addClass('fa-lock');
                        $this.css('color', '#d9534f');
                    }
                }, 10000);
            }
        });

        function confirmDelete(documentId, documentType, customerId) {
            $('#deleteMessage').text('Are you sure you want to delete this ' + documentType + '? This action cannot be undone.');
            $('#deleteCustomerId').val(customerId);
            $('#deleteModal').modal('show');

            $('#confirmDelete').off('click').on('click', function () {
                var form = $('#deleteForm');
                form.attr('action', '@Url.Action("Delete", "Documents")' + '/' + documentId);
                form.submit();
            });
        }

        // Toast animations
        $(document).ready(function () {
            $('.app-toast').each(function (index) {
                var $toast = $(this);
                $toast.css({ 'opacity': '0', 'transform': 'translateX(400px)' });
                setTimeout(function () {
                    $toast.animate({ 'opacity': '1' }, 400);
                    $toast.css({ 'transform': 'translateX(0)', 'transition': 'transform 0.4s ease-out' });
                }, index * 100);
            });
        });

        // Auto-hide success messages
        setTimeout(function () {
            $('.app-toast:not(.app-toast-error)').each(function (index) {
                var $toast = $(this);
                setTimeout(function () {
                    $toast.css({ 'transform': 'translateX(400px)', 'transition': 'all 0.3s ease-in', 'opacity': '0' });
                    setTimeout(function () { $toast.remove(); }, 300);
                }, index * 100);
            });
        }, 5000);

        // Manual close
        $('.app-toast-close').on('click', function () {
            var $toast = $(this).closest('.app-toast');
            $toast.css({ 'transform': 'translateX(400px)', 'transition': 'all 0.3s ease-in', 'opacity': '0' });
            setTimeout(function () { $toast.remove(); }, 300);
        });
    </script>
}