@model TechSolutions.Models.IdentificationDocument

@{
    ViewBag.Title = "Edit ID Document";
    var customer = ViewBag.Customer as TechSolutions.Models.Customer;
}

<div class="app-theme">
    <!-- Toast Alerts -->
    @if (TempData["SuccessMessage"] != null || TempData["ErrorMessage"] != null)
    {
        <div id="toastContainer" style="position: fixed; top: 80px; right: 20px; z-index: 9999; min-width: 350px; max-width: 500px;">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible app-toast" role="alert" style="margin-bottom: 10px; box-shadow: 0 8px 16px rgba(0,0,0,0.2); border-left: 4px solid #3c763d; background-color: #dff0d8; border-radius: var(--border-radius);">
                    <button type="button" class="close app-toast-close" aria-label="Close" style="opacity: 1; color: #3c763d; font-size: 24px; font-weight: 300; line-height: 1; text-shadow: none;">
                        <span aria-hidden="true">&times;</span>
                    </button>
                    <div style="padding-right: 20px;">
                        <strong style="color: #3c763d;"><i class="fa fa-check-circle"></i> Success!</strong>
                        <div style="margin-top: 5px; color: #3c763d;">@TempData["SuccessMessage"]</div>
                    </div>
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible app-toast app-toast-error" role="alert" style="margin-bottom: 10px; box-shadow: 0 8px 16px rgba(0,0,0,0.2); border-left: 4px solid #a94442; background-color: #f2dede; border-radius: var(--border-radius);">
                    <button type="button" class="close app-toast-close" aria-label="Close" style="opacity: 1; color: #a94442; font-size: 24px; font-weight: 300; line-height: 1; text-shadow: none;">
                        <span aria-hidden="true">&times;</span>
                    </button>
                    <div style="padding-right: 20px;">
                        <strong style="color: #a94442;"><i class="fa fa-exclamation-triangle"></i> Error!</strong>
                        <div style="margin-top: 5px; color: #a94442;">@TempData["ErrorMessage"]</div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="container-fluid">
        <!-- Back Button -->
        <div class="row" style="margin-bottom: 15px;">
            <div class="col-md-8" style="margin: 0 auto; float: none;">
                <a href="@Url.Action("Index", new { customerId = customer.CustomerID })" class="btn btn-default">
                    <i class="fa fa-arrow-left"></i> Back to Documents List
                </a>
            </div>
        </div>

        <!-- Page Header -->
        <div class="row" style="margin-bottom: 20px;">
            <div class="col-md-8" style="margin: 0 auto; float: none;">
                <div class="panel panel-primary">
                    <div class="panel-heading" style="background: linear-gradient(135deg, var(--color-primary), var(--color-secondary)); border: none;">
                        <h3 class="panel-title" style="color: #fff; font-size: 18px; margin: 0;">
                            <i class="fa fa-pencil"></i> Edit ID Document - @customer.FullName
                        </h3>
                    </div>
                    <div class="panel-body" style="padding: 15px; background: var(--color-bg);">
                        <p style="margin: 0; color: #666;">
                            <strong>Customer Code:</strong> <span style="color: var(--color-primary); font-weight: 600;">@customer.CustomerCode</span>
                            <span style="margin: 0 10px;">|</span>
                            <strong>Document Type:</strong> <span style="color: var(--color-primary); font-weight: 600;">@Model.DocumentType</span>
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Edit Form -->
        <div class="row">
            <div class="col-md-8" style="margin: 0 auto; float: none;">
                <div class="panel panel-default">
                    <div class="panel-body" style="padding: 30px;">
                        @using (Html.BeginForm("Edit", "Documents", FormMethod.Post, new { @class = "form-horizontal", id = "documentEditForm" }))
                        {
                            @Html.AntiForgeryToken()
                            @Html.HiddenFor(m => m.DocumentID)
                            @Html.HiddenFor(m => m.CustomerID)
                            @Html.HiddenFor(m => m.CreatedDate)
                            @Html.HiddenFor(m => m.DocumentType)
                            @Html.HiddenFor(m => m.DocumentFilePath)
                            @Html.HiddenFor(m => m.OriginalFileName)
                            @Html.HiddenFor(m => m.FileType)
                            @Html.HiddenFor(m => m.FileSizeBytes)

                            @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                            <!-- Document Type (Read-only) -->
                            <h4 style="color: var(--color-primary); margin-top: 0; margin-bottom: 20px; padding-bottom: 10px; border-bottom: 2px solid var(--color-bg);">
                                <i class="fa fa-file-text"></i> Document Type
                            </h4>

                            <div class="form-group">
                                <label class="control-label">Document Type</label>
                                <input type="text" class="form-control" value="@Model.DocumentType" disabled style="background: #f5f5f5; cursor: not-allowed;" />
                                <span class="help-block">
                                    <i class="fa fa-lock"></i> Document type cannot be changed. Create a new document if you need a different type.
                                </span>
                            </div>

                            <!-- Document Number Section -->
                            <h4 style="color: var(--color-primary); margin-top: 30px; margin-bottom: 20px; padding-bottom: 10px; border-bottom: 2px solid var(--color-bg);">
                                <i class="fa fa-hashtag"></i> Document Number
                            </h4>

                            <!-- ID Number Section -->
                            if (Model.DocumentType == "National ID Card" || Model.DocumentType == "State ID Card" || Model.DocumentType == "Driver's License")
                            {
                                <div class="form-group">
                                    @Html.LabelFor(m => m.IDNumber, new { @class = "control-label" })
                                    @Html.TextBoxFor(m => m.IDNumber, new { @class = "form-control", placeholder = "South African ID Number (13 digits)", maxlength = "13", pattern = "[0-9]{13}", required = "required" })
                                    @Html.ValidationMessageFor(m => m.IDNumber, "", new { @class = "text-danger" })
                                    <span class="help-block">
                                        <i class="fa fa-lock text-danger"></i> Encrypted | Format: 13 digits (YYMMDDGSSSCAZ)
                                    </span>
                                </div>
                            }

                            <!-- Passport Number Section -->
                            if (Model.DocumentType == "Passport")
                            {
                                <div class="form-group">
                                    @Html.LabelFor(m => m.PassportNumber, new { @class = "control-label" })
                                    @Html.TextBoxFor(m => m.PassportNumber, new { @class = "form-control", placeholder = "Passport Number", required = "required" })
                                    @Html.ValidationMessageFor(m => m.PassportNumber, "", new { @class = "text-danger" })
                                    <span class="help-block">
                                        <i class="fa fa-lock text-danger"></i> Encrypted
                                    </span>
                                </div>
                            }

                            <!-- Professional Registration / Other Section -->
                            if (Model.DocumentType == "Birth Certificate" || Model.DocumentType == "Social Security Card" || Model.DocumentType == "Other")
                            {
                                <div class="form-group">
                                    @if (Model.DocumentType == "Birth Certificate")
                                    {
                                        <label class="control-label">Birth Certificate Number</label>
                                        @Html.TextBoxFor(m => m.ProfessionalRegNumber, new { @class = "form-control", placeholder = "Birth Certificate Number", required = "required" })
                                    }
                                    else if (Model.DocumentType == "Social Security Card")
                                    {
                                        <label class="control-label">Social Security Number</label>
                                        @Html.TextBoxFor(m => m.ProfessionalRegNumber, new { @class = "form-control", placeholder = "Social Security Number", required = "required" })
                                    }
                                    else
                                    {
                                        @Html.LabelFor(m => m.ProfessionalRegNumber, new { @class = "control-label" })
                                        @Html.TextBoxFor(m => m.ProfessionalRegNumber, new { @class = "form-control", placeholder = "e.g., HPCSA MP1234567", required = "required" })
                                    }
                                    @Html.ValidationMessageFor(m => m.ProfessionalRegNumber, "", new { @class = "text-danger" })
                                    <span class="help-block">
                                        <i class="fa fa-lock text-danger"></i> Encrypted
                                    </span>
                                </div>
                            }

                            <!-- Uploaded Document -->
                            if (!string.IsNullOrEmpty(Model.DocumentFilePath))
                            {
                                <h4 style="color: var(--color-primary); margin-top: 30px; margin-bottom: 20px; padding-bottom: 10px; border-bottom: 2px solid var(--color-bg);">
                                    <i class="fa fa-file"></i> Uploaded Document
                                </h4>

                                <div class="alert alert-info" style="border-left: 4px solid #31708f;">
                                    <div class="row">
                                        <div class="col-md-9">
                                            <p style="margin: 0;">
                                                <i class="fa fa-file-@(Model.FileType == "pdf" ? "pdf" : "image")-o"></i>
                                                <strong>@Model.OriginalFileName</strong>
                                            </p>
                                            <p style="margin: 5px 0 0 0; color: #666; font-size: 12px;">
                                                Size: @((Model.FileSizeBytes ?? 0) / 1024) KB |
                                                Type: @Model.FileType.ToUpper() |
                                                <i class="fa fa-lock text-success"></i> Encrypted
                                            </p>
                                        </div>
                                        <div class="col-md-3" style="display: flex; align-items: center; justify-content: flex-end;">
                                            <a href="@Url.Action("Download", "Documents", new { id = Model.DocumentID })" class="btn btn-primary" target="_blank" title="Download Document">
                                                <i class="fa fa-download"></i> Download
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-warning" style="border-left: 4px solid #f0ad4e; margin-top: 30px;">
                                    <i class="fa fa-exclamation-triangle"></i> <strong>No document uploaded.</strong> This record was created without a file attachment.
                                </div>
                            }

                            <!-- Issuing Information -->
                            <h4 style="color: var(--color-primary); margin-top: 30px; margin-bottom: 20px; padding-bottom: 10px; border-bottom: 2px solid var(--color-bg);">
                                <i class="fa fa-building"></i> Issuing Information
                            </h4>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        @Html.LabelFor(m => m.IssuingCountry, new { @class = "control-label" })
                                        @Html.TextBoxFor(m => m.IssuingCountry, new { @class = "form-control", required = "required" })
                                        @Html.ValidationMessageFor(m => m.IssuingCountry, "", new { @class = "text-danger" })
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="form-group">
                                        @Html.LabelFor(m => m.IssuingAuthority, new { @class = "control-label" })
                                        @Html.TextBoxFor(m => m.IssuingAuthority, new { @class = "form-control" })
                                        @Html.ValidationMessageFor(m => m.IssuingAuthority, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                            </div>

                            <!-- Validity Dates -->
                            <h4 style="color: var(--color-primary); margin-top: 30px; margin-bottom: 20px; padding-bottom: 10px; border-bottom: 2px solid var(--color-bg);">
                                <i class="fa fa-calendar"></i> Validity Dates
                            </h4>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        @Html.LabelFor(m => m.IssueDate, new { @class = "control-label" })
                                        @Html.TextBoxFor(m => m.IssueDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date", max = DateTime.Now.ToString("yyyy-MM-dd") })
                                        @Html.ValidationMessageFor(m => m.IssueDate, "", new { @class = "text-danger" })
                                        <span class="help-block">Issue date cannot be in the future</span>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="form-group">
                                        @Html.LabelFor(m => m.ExpiryDate, new { @class = "control-label" })
                                        @Html.TextBoxFor(m => m.ExpiryDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                                        @Html.ValidationMessageFor(m => m.ExpiryDate, "", new { @class = "text-danger" })
                                        <span class="help-block">Leave blank if document doesn't expire</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Verification -->
                            <h4 style="color: var(--color-primary); margin-top: 30px; margin-bottom: 20px; padding-bottom: 10px; border-bottom: 2px solid var(--color-bg);">
                                <i class="fa fa-check-square"></i> Verification
                            </h4>

                            <div class="form-group">
                                <div class="checkbox">
                                    <label style="font-weight: 600;">
                                        @Html.CheckBoxFor(m => m.IsVerified)
                                        <span style="margin-left: 5px;">Document has been verified</span>
                                    </label>
                                </div>
                            </div>

                            <div class="form-group">
                                @Html.LabelFor(m => m.VerificationNotes, new { @class = "control-label" })
                                @Html.TextAreaFor(m => m.VerificationNotes, new { @class = "form-control", rows = "3", maxlength = "500" })
                                @Html.ValidationMessageFor(m => m.VerificationNotes, "", new { @class = "text-danger" })
                            </div>

                            <!-- Action Buttons -->
                            <hr style="margin: 30px 0; border-color: var(--color-bg);" />

                            <div class="form-group" style="margin-bottom: 0;">
                                <div class="text-center">
                                    <button type="submit" class="btn btn-primary btn-lg" style="min-width: 150px; margin-right: 10px;">
                                        <i class="fa fa-save"></i> Update Document
                                    </button>
                                    <a href="@Url.Action("Index", new { customerId = customer.CustomerID })" class="btn btn-default btn-lg" style="min-width: 150px;">
                                        <i class="fa fa-times"></i> Cancel
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")

    <script>
        // Form validation before submit
        $('#documentEditForm').on('submit', function (e) {
            // Validate dates if provided
            var issueDate = $('#IssueDate').val();
            var expiryDate = $('#ExpiryDate').val();

            if (issueDate && expiryDate) {
                if (new Date(expiryDate) <= new Date(issueDate)) {
                    e.preventDefault();
                    alert('Expiry date must be after issue date.');
                    $('#ExpiryDate').focus();
                    return false;
                }
            }

            return true;
        });

        // Toast animations
        $(document).ready(function () {
            $('.app-toast').each(function (index) {
                var $toast = $(this);
                $toast.css({ 'opacity': '0', 'transform': 'translateX(400px)' });
                setTimeout(function () {
                    $toast.animate({ 'opacity': '1' }, 400);
                    $toast.css({ 'transform': 'translateX(0)', 'transition': 'transform 0.4s ease-out' });
                }, index * 100);
            });
        });

        setTimeout(function () {
            $('.app-toast:not(.app-toast-error)').each(function (index) {
                var $toast = $(this);
                setTimeout(function () {
                    $toast.css({ 'transform': 'translateX(400px)', 'transition': 'all 0.3s ease-in', 'opacity': '0' });
                    setTimeout(function () { $toast.remove(); }, 300);
                }, index * 100);
            });
        }, 5000);

        $('.app-toast-close').on('click', function () {
            var $toast = $(this).closest('.app-toast');
            $toast.css({ 'transform': 'translateX(400px)', 'transition': 'all 0.3s ease-in', 'opacity': '0' });
            setTimeout(function () { $toast.remove(); }, 300);
        });
    </script>
}